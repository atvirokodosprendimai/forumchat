package templ

type Viewer struct {
	IsAuthed      bool
	DisplayName   string
	Role          string // member|moderator|admin
	CommunityName string
	CommunitySlug string // empty when no community is in scope (dashboard, login pages)
}

// InitialSignals — global signal bag rendered on every page.
// Every data-bind / data-on-click POST sees these as their starting state.
const InitialSignals = `{
	"email":"",
	"password":"",
	"invite_code":"",
	"display_name":"",
	"avatar_url":"",
	"subject":"",
	"body":"",
	"quoted_post_id":"",
	"reply_quote_label":"",
	"reply_to_id":"",
	"max_uses":"",
	"cleanup_chat":false,
	"cleanup_threads":false,
	"cleanup_posts":false,
	"ban_hours":0,
	"bm_open_msg":"",
	"bm_new_title":"",
	"bm_new_category":"",
	"bm_new_note":"",
	"bm_title":"",
	"bm_category":"",
	"bm_from":"",
	"bm_to":"",
	"image_data":"",
	"rename_open":false,
	"new_subject":"",
	"cc_name":"",
	"cc_slug":"",
	"cc_member_email":"",
	"am_email":"",
	"am_role":"member",
	"join_password":"",
	"todo_open_source":"",
	"todo_title":"",
	"todo_category":"",
	"todo_note":""
}`

templ Layout(title string, v Viewer) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width,initial-scale=1"/>
			<title>{ title } — forumchat</title>
			<link rel="stylesheet" href={ "/static/app.css?v=" + AssetVer("app.css") }/>
				<link rel="manifest" href={ "/static/manifest.webmanifest?v=" + AssetVer("manifest.webmanifest") }/>
				<link rel="icon" type="image/svg+xml" href="/static/icon.svg"/>
				<link rel="apple-touch-icon" href="/static/icon-192.png"/>
				<meta name="theme-color" content="#1f6feb"/>
				<meta name="mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-title" content="forumchat"/>
			<script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.2/bundles/datastar.js"></script>
			<script src={ "/static/paste.js?v=" + AssetVer("paste.js") } defer></script>
		</head>
		<body data-signals={ InitialSignals }>
			<header class="topbar">
				<a href="/" class="brand">forumchat</a>
				<nav>
					if v.IsAuthed {
						if v.CommunitySlug != "" {
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/chat") }>Chat</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/forum") }>Forum</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/bookmarks") }>Bookmarks</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/todos") }>Todos</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/history") }>History</a>
							if v.Role == "admin" {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/admin") }>Admin</a>
							}
						}
						<a href="/">Communities</a>
						<a href="/profile">{ v.DisplayName }</a>
						<button class="ghost" data-on:click="@post('/logout')">Sign out</button>
					} else {
						<a href="/login">Sign in</a>
						<a href="/register">Register</a>
					}
				</nav>
			</header>
			<main>
				{ children... }
			</main>
			<footer class="site-footer">
				<span class="muted">Built by <a href="https://ituoga.lt" target="_blank" rel="noopener">ituoga.lt</a> and Claude</span>
			</footer>
		</body>
	</html>
}

templ Hello(communityName string) {
	@Layout("Welcome", Viewer{}) {
		<section class="card narrow">
			<h1>Welcome to { communityName }</h1>
			<p class="muted">A community space — one realtime chat channel and a forum, in one place.</p>
			<p>
				<a class="btn" href="/register">Get started</a>
				&nbsp;
				<a class="btn ghost" href="/login">Sign in</a>
			</p>
			<p class="muted">Sign-up is invite-only. Ask an admin for an invite code.</p>
		</section>
	}
}

templ Home(v Viewer) {
	@Layout("Home", v) {
		<section class="card">
			<h1>Welcome back, { v.DisplayName }</h1>
			<p class="muted">You're signed in to <strong>{ v.CommunityName }</strong>.</p>
			<p class="primary-nav">
				<a class="btn" href="/chat">Open chat</a>
				<a class="btn ghost" href="/forum">Open forum</a>
				<a class="btn ghost" href="/profile">Profile</a>
			</p>
		</section>
	}
}

templ ClockFragment(now string) {
	<div id="clock">{ now }</div>
}

templ DebugClock() {
	@Layout("Clock", Viewer{}) {
		<section class="card">
			<h1>datastar SSE clock</h1>
			<p class="muted">Ticks every second via NATS round-trip.</p>
			<div id="clock" data-init="@get('/_debug/clock/stream')">— waiting —</div>
		</section>
	}
}
