templ Layout(title string, v Viewer) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width,initial-scale=1"/>
			<title>{ title } — forumchat</title>
			<style>
				/* FOUC guard — inline so it applies at first paint with no
				   external dependency. Hides data-show dialogs/popups until
				   Datastar hydrates and nav.js strips data-cloak. Mirrors the
				   rule in app.css; the inline copy is the load-bearing one
				   because an external stylesheet can lose the race to first
				   paint, leaving modals briefly visible. */
				[data-cloak]{display:none!important}
			</style>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
				<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
				<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=JetBrains+Mono:wght@400;600&display=swap"/>
				@InlineStyle("app.css")
				<link rel="manifest" href={ "/static/manifest.webmanifest?v=" + AssetVer("manifest.webmanifest") }/>
				<link rel="icon" type="image/svg+xml" href="/static/icon.svg"/>
				<link rel="apple-touch-icon" href="/static/icon-192.png"/>
				<meta name="theme-color" content={ themeColor(v.CommunitySlug) }/>
				<meta name="mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-title" content="forumchat"/>
			<script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.2/bundles/datastar.js"></script>
			<script src={ "/static/paste.js?v=" + AssetVer("paste.js") } defer></script>
			<script src={ "/static/mention.js?v=" + AssetVer("mention.js") } defer></script>
			<script src={ "/static/translate.js?v=" + AssetVer("translate.js") } defer></script>
			<script src={ "/static/codeblock.js?v=" + AssetVer("codeblock.js") } defer></script>
		</head>
		<body
			data-signals={ InitialSignals }
			data-init="document.querySelectorAll('[data-cloak]').forEach(e => e.removeAttribute('data-cloak'))"
			data-class:nav-open="$_nav_open"
			data-class:presence-open="$_presence_open"
			data-on:click__window="document.querySelectorAll('details.msg-menu[open], details.topnav-menu[open]').forEach(d => d.contains(evt.target) || (d.open=false))"
			data-on:keydown__window="if(evt.key==='Escape'){$_nav_open=false; $_presence_open=false; $_yt_open=false; $_yt_id=''; $_html_open=false; document.querySelectorAll('details.msg-menu[open], details.topnav-menu[open]').forEach(d => d.open=false)}"
		>
			<script src={ "/static/nav.js?v=" + AssetVer("nav.js") } defer></script>
			<header class="topbar">
				<button class="topbar-hamburger" aria-label="Toggle navigation"
					type="button" data-on:click="$_nav_open = !$_nav_open">
					<span class="hamburger-bar"></span>
					<span class="hamburger-bar"></span>
					<span class="hamburger-bar"></span>
				</button>
				<a href="/" class="brand">forumchat</a>
				if v.IsAuthed {
					@CommunityTopNav(v)
				}
			</header>
			<div class="nav-overlay" data-on:click="$_nav_open = false"></div>
			<aside class="sidebar">
				<a href="/" class="sidebar-brand">forumchat</a>
				<nav data-on:click="evt.target.closest('a,button') && ($_nav_open = false)">
					if v.IsAuthed {
						<h3 class="sidebar-group">You</h3>
						if MailboxEnabled && IsSuperAdmin(ctx) {
							<a href="/inbox" aria-current={ navActive(ctx, "/inbox") }><span class="sb-icon" aria-hidden="true">📥</span>Inbox</a>
						}
						if IsAdminOfAnyCommunity(ctx) {
							<a href="/issues" aria-current={ navActive(ctx, "/issues") }><span class="sb-icon" aria-hidden="true">🐞</span>Issues</a>
						}
						if IsSuperAdmin(ctx) {
							<a href="/superadmin" aria-current={ navActive(ctx, "/superadmin") }><span class="sb-icon" aria-hidden="true">🛡</span>Platform</a>
							<a href="/superadmin/chat" aria-current={ navActive(ctx, "/superadmin/chat") }><span class="sb-icon" aria-hidden="true">💬</span>Chats</a>
							if SupportInboxEnabled {
								<a href="/support-inbox" aria-current={ navActive(ctx, "/support-inbox") }><span class="sb-icon" aria-hidden="true">📨</span>Support inbox</a>
							}
						}
						<a href="/messages" class="pm-nav-link" aria-current={ navActive(ctx, "/messages") }>
							<span class="sb-icon" aria-hidden="true">✉</span>
							<span>Messages</span>
							@MessagesBadge(0)
						</a>
						<a href="/explore" aria-current={ navActive(ctx, "/explore") }><span class="sb-icon" aria-hidden="true">🔭</span>Explore</a>
						if SupportInboxEnabled {
							<a href="/report-issue" aria-current={ navActive(ctx, "/report-issue") }><span class="sb-icon" aria-hidden="true">🛟</span>Report issue</a>
						}
						if TimeEnabled {
							<a href="/journal" aria-current={ navActive(ctx, "/journal") }><span class="sb-icon" aria-hidden="true">⏱</span>Journal</a>
						}
						<a href="/" aria-current={ navActive(ctx, "/") }><span class="sb-icon" aria-hidden="true">🏠</span>Communities</a>
						<a href="/profile" class="sidebar-profile">
							<span class="sb-avatar" aria-hidden="true">{ initial(v.DisplayName) }</span>
							<span class="sb-name">{ v.DisplayName }</span>
						</a>
						<button class="ghost" data-on:click="@post('/logout')"><span class="sb-icon" aria-hidden="true">↩</span>Sign out</button>
					} else {
						<a href="/login"><span class="sb-icon" aria-hidden="true">→</span>Sign in</a>
						<a href="/register"><span class="sb-icon" aria-hidden="true">＋</span>Register</a>
					}
				</nav>
			</aside>
			<main>
				{ children... }
			</main>
			if v.IsAuthed {
				if v.CommunitySlug != "" {
					// Global chat event stream — opened on every page in
					// the community so a viewer on /forum still hears a
					// ping when a new chat message lands. Server emits
					// only `window.fcChatPing()` calls; chat-events.js
					// decides sound + Notification.
					<div id="chat-events-open" hidden data-init={ "@get('/c/" + v.CommunitySlug + "/chat/events', {openWhenHidden: true})" }></div>
					<script src={ "/static/chat-events.js?v=" + AssetVer("chat-events.js") } defer></script>
				}
				<div id="pm-stream-open" hidden data-init="@get('/messages/stream', {openWhenHidden: true})"></div>
				<div class="pm-toast" data-cloak data-show="$_pm_toast_text !== ''"
					data-on:animationend="$_pm_toast_text=''; $_pm_toast_href=''">
					<a class="pm-toast-link" data-attr:href="$_pm_toast_href || '/messages'">
						<span class="pm-toast-icon">✓</span>
						<span class="pm-toast-text" data-text="$_pm_toast_text"></span>
						<span class="pm-toast-cta">open</span>
					</a>
					<button class="pm-toast-close" aria-label="dismiss" data-on:click="$_pm_toast_text=''; $_pm_toast_href=''">✕</button>
				</div>
			}
			// YouTube lightbox — a single global overlay outside #messages, so a
			// chat fat-morph never resets a playing video. The facade injected by
			// render.EmbedYouTube sets $_yt_id + $_yt_open on click; the iframe src
			// is bound to the signal so the player loads only while open and clears
			// on close (stops playback). youtube-nocookie for privacy.
			<div class="yt-lightbox" data-cloak data-show="$_yt_open"
				data-on:click="$_yt_open=false;$_yt_id=''">
				<div class="yt-lightbox-inner" data-on:click="evt.stopPropagation()">
					<button type="button" class="yt-lightbox-close" aria-label="Close video"
						data-on:click="$_yt_open=false;$_yt_id=''">✕</button>
					<iframe class="yt-lightbox-frame" title="YouTube video player"
						allow="autoplay; encrypted-media; picture-in-picture; fullscreen" allowfullscreen
						data-attr:src="$_yt_open ? ('https://www.youtube-nocookie.com/embed/'+$_yt_id+'?autoplay=1&rel=0') : ''"></iframe>
				</div>
			</div>
			// HTML preview lightbox — a single global sandboxed iframe outside any
			// morph target, so opening it never disturbs chat/agent streams. The
			// "👁 Preview" button on an HTML code block (render.DownloadableCode)
			// loads the block's raw source into #fc-html-frame via
			// window.fcPreviewCode, then flips $_html_open. sandbox WITHOUT
			// allow-same-origin keeps agent HTML isolated from the app origin; the
			// data-effect blanks srcdoc on close so any script/audio stops.
			<div class="html-lightbox" data-cloak data-show="$_html_open"
				data-on:click="$_html_open=false">
				<div class="html-lightbox-inner" data-on:click="evt.stopPropagation()">
					<div class="html-lightbox-bar">
						<span class="muted">HTML preview — sandboxed</span>
						<button type="button" class="html-lightbox-close" aria-label="Close preview"
							data-on:click="$_html_open=false">✕</button>
					</div>
					<iframe id="fc-html-frame" class="html-lightbox-frame" title="HTML preview"
						sandbox="allow-scripts allow-modals allow-popups allow-forms"
						data-effect="if(!$_html_open){el.srcdoc=''}"></iframe>
				</div>
			</div>
			<footer class="site-footer">
				<span class="muted">Built by <a href="https://ituoga.lt" target="_blank" rel="noopener">ituoga.lt</a> and Claude</span>
				<span class="fc-version" title="Build version">{ Version }</span>
			</footer>
		</body>
	</html>
}

// CommunityTopNav renders the persistent top-bar context strip. When the
// viewer is inside a community it shows a switcher chip (community name → all
// communities), the primary community pills, and a "More" dropdown for the
// long tail. Outside a community it shows a single "Communities" chip so the
// bar keeps its height on every page — entering a community never shifts the
// layout. ctx is the implicit templ context, used by navActive for active
// highlighting (server-rendered, no client DOM walk).
templ CommunityTopNav(v Viewer) {
	if v.CommunitySlug != "" {
		<div class="topnav">
			<details class="topnav-menu topnav-switcher">
				<summary>
					<span class="topnav-ava" aria-hidden="true">{ initial(v.CommunityName) }</span>
					<span class="topnav-comm">{ v.CommunityName }</span>
					<span class="topnav-caret" aria-hidden="true">▾</span>
				</summary>
				<div class="topnav-pop topnav-pop-switcher">
					if comms := TopNavCommunities(ctx); len(comms) > 0 {
						<div class="topnav-pop-label">Switch community</div>
						for _, c := range comms {
							<a class="topnav-comm-item" href={ templ.URL("/c/" + c.Slug + "/chat") }
								aria-current={ ariaPage(c.Slug == v.CommunitySlug) }>
								<span class="topnav-ava topnav-ava-sm" aria-hidden="true">{ initial(c.Name) }</span>
								<span class="topnav-comm-name">{ c.Name }</span>
								if c.Slug == v.CommunitySlug {
									<span class="topnav-comm-check" aria-hidden="true">✓</span>
								}
							</a>
						}
						<div class="topnav-pop-sep" role="separator"></div>
					}
					<a href="/"><span class="sb-icon" aria-hidden="true">🏠</span>All communities</a>
					<a href="/explore"><span class="sb-icon" aria-hidden="true">🔭</span>Explore</a>
				</div>
			</details>
			<nav class="topnav-pills" aria-label="Community navigation">
				<a href={ templ.URL("/c/" + v.CommunitySlug + "/chat") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/chat") }><span class="sb-icon" aria-hidden="true">💬</span>Chat</a>
				<a href={ templ.URL("/c/" + v.CommunitySlug + "/forum") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/forum") }><span class="sb-icon" aria-hidden="true">📋</span>Threads</a>
				<a href={ templ.URL("/c/" + v.CommunitySlug + "/rooms") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/rooms") }><span class="sb-icon" aria-hidden="true">🎥</span>Rooms</a>
				<a href={ templ.URL("/c/" + v.CommunitySlug + "/search") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/search") }><span class="sb-icon" aria-hidden="true">🔍</span>Search</a>
				if AIEnabled && CommunityAIEnabled(ctx) {
					<a href={ templ.URL("/c/" + v.CommunitySlug + "/agent") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/agent") }><span class="sb-icon" aria-hidden="true">🤖</span>Agent</a>
				}
				if SaaSEnabled && v.Role == "owner" {
					<a href={ templ.URL("/c/" + v.CommunitySlug + "/settings") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/settings") }><span class="sb-icon" aria-hidden="true">⚙</span>Settings</a>
				}
			</nav>
			<details class="topnav-menu topnav-more">
				<summary aria-current={ ariaPage(topnavMoreActive(ctx, v.CommunitySlug)) }>
					<span class="topnav-more-label">More</span>
					<span class="topnav-caret" aria-hidden="true">▾</span>
				</summary>
				<div class="topnav-pop">
					<a href={ templ.URL("/c/" + v.CommunitySlug + "/bookmarks") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/bookmarks") }><span class="sb-icon" aria-hidden="true">★</span>Bookmarks</a>
					<a href={ templ.URL("/c/" + v.CommunitySlug + "/todos") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/todos") }><span class="sb-icon" aria-hidden="true">☑</span>Todos</a>
					if ProjectsEnabled {
						<a href={ templ.URL("/c/" + v.CommunitySlug + "/projects") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/projects") }><span class="sb-icon" aria-hidden="true">📂</span>Projects</a>
					}
					if TimeEnabled {
						<a href={ templ.URL("/c/" + v.CommunitySlug + "/budget") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/budget") }><span class="sb-icon" aria-hidden="true">📊</span>Budget</a>
					}
					if GuestAccessEnabled && RoleIsMod(v.Role) {
						<a href={ templ.URL("/c/" + v.CommunitySlug + "/lobbies") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/lobbies") }><span class="sb-icon" aria-hidden="true">🚪</span>Lobbies</a>
					}
					<a href={ templ.URL("/c/" + v.CommunitySlug + "/history") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/history") }><span class="sb-icon" aria-hidden="true">🕘</span>History</a>
					<a href={ templ.URL("/c/" + v.CommunitySlug + "/notifications") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/notifications") }><span class="sb-icon" aria-hidden="true">🔔</span>Notifications</a>
					if RoleIsAdmin(v.Role) {
						<a href={ templ.URL("/c/" + v.CommunitySlug + "/admin") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/admin") }><span class="sb-icon" aria-hidden="true">⚙</span>Admin</a>
					}
				</div>
			</details>
		</div>
	} else {
		<div class="topnav">
			<a href="/" class="topnav-chip" aria-current={ navActive(ctx, "/") }><span class="sb-icon" aria-hidden="true">🏠</span>Communities</a>
		</div>
	}
}

templ Hello(communityName string) {
	@Layout("Welcome", Viewer{}) {
		<section class="card narrow">
			<h1>Welcome to { communityName }</h1>
			<p class="muted">A community space — one realtime chat channel and a forum, in one place.</p>
			<p>
				<a class="btn" href="/register">Get started</a>
				&nbsp;
				<a class="btn ghost" href="/login">Sign in</a>
			</p>
			<p class="muted">Sign-up is invite-only. Ask an admin for an invite code.</p>
		</section>
	}
}

templ Home(v Viewer) {
	@Layout("Home", v) {
		<section class="card">
			<h1>Welcome back, { v.DisplayName }</h1>
			<p class="muted">You're signed in to <strong>{ v.CommunityName }</strong>.</p>
			<p class="primary-nav">
				<a class="btn" href="/chat">Open chat</a>
				<a class="btn ghost" href="/forum">Open forum</a>
				<a class="btn ghost" href="/profile">Profile</a>
			</p>
		</section>
	}
}

// PageHeader is the shared page-title block used across every community
// page: a left-aligned title, a right-aligned actions slot (the page's
// primary action — "New thread", "Create project", …), and an optional
// muted subtitle. Standardising this is what makes the pages feel like one
// app instead of N differently-arranged screens (see AGENTS.md design
// system). It emits the existing .page-head row, so forum's prior markup
// is byte-compatible.
//
// Usage:
//
//	@PageHeader("Projects", "Shared pages for documents…") {
//	    <button class="btn" data-on:click="…">+ New project</button>
//	}
//
// Pass an empty subtitle to omit it; pass no children for no action (the
// actions slot collapses via `.page-head-actions:empty`).
templ PageHeader(title, subtitle string) {
	<header class="page-header">
		<div class="page-head">
			<h1>{ title }</h1>
			<div class="page-head-actions">
				{ children... }
			</div>
		</div>
		if subtitle != "" {
			<p class="page-subtitle">{ subtitle }</p>
		}
	</header>
}

templ ClockFragment(now string) {
	<div id="clock">{ now }</div>
}

templ DebugClock() {
	@Layout("Clock", Viewer{}) {
		<section class="card">
			<h1>datastar SSE clock</h1>
			<p class="muted">Ticks every second via NATS round-trip.</p>
			<div id="clock" data-init="@get('/_debug/clock/stream')">— waiting —</div>
		</section>
	}
}
