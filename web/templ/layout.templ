templ Layout(title string, v Viewer) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width,initial-scale=1"/>
			<title>{ title } — forumchat</title>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
				<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
				<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=JetBrains+Mono:wght@400;600&display=swap"/>
				<link rel="stylesheet" href={ "/static/app.css?v=" + AssetVer("app.css") }/>
				<link rel="manifest" href={ "/static/manifest.webmanifest?v=" + AssetVer("manifest.webmanifest") }/>
				<link rel="icon" type="image/svg+xml" href="/static/icon.svg"/>
				<link rel="apple-touch-icon" href="/static/icon-192.png"/>
				<meta name="theme-color" content={ themeColor(v.CommunitySlug) }/>
				<meta name="mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-title" content="forumchat"/>
			<script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.2/bundles/datastar.js"></script>
			<script src={ "/static/paste.js?v=" + AssetVer("paste.js") } defer></script>
			<script src={ "/static/mention.js?v=" + AssetVer("mention.js") } defer></script>
		</head>
		<body
			data-signals={ InitialSignals }
			data-class:nav-open="$_nav_open"
			data-class:presence-open="$_presence_open"
			data-on:click__window="document.querySelectorAll('details.msg-menu[open]').forEach(d => d.contains(evt.target) || (d.open=false))"
			data-on:keydown__window="if(evt.key==='Escape'){$_nav_open=false; $_presence_open=false; document.querySelectorAll('details.msg-menu[open]').forEach(d => d.open=false)}"
		>
			<script src={ "/static/nav.js?v=" + AssetVer("nav.js") } defer></script>
			<header class="topbar">
				<button class="topbar-hamburger" aria-label="Toggle navigation"
					type="button" data-on:click="$_nav_open = !$_nav_open">
					<span class="hamburger-bar"></span>
					<span class="hamburger-bar"></span>
					<span class="hamburger-bar"></span>
				</button>
				<a href="/" class="brand">forumchat</a>
			</header>
			<div class="nav-overlay" data-on:click="$_nav_open = false"></div>
			<aside class="sidebar">
				<a href="/" class="sidebar-brand">forumchat</a>
				<nav data-on:click="evt.target.closest('a,button') && ($_nav_open = false)">
					if v.IsAuthed {
						<h3 class="sidebar-group">You</h3>
						if MailboxEnabled && IsAdminOfAnyCommunity(ctx) {
							<a href="/inbox" aria-current={ navActive(ctx, "/inbox") }><span class="sb-icon" aria-hidden="true">📥</span>Inbox</a>
						}
						if IsAdminOfAnyCommunity(ctx) {
							<a href="/issues" aria-current={ navActive(ctx, "/issues") }><span class="sb-icon" aria-hidden="true">🐞</span>Issues</a>
						}
						if IsSuperAdmin(ctx) {
							<a href="/superadmin" aria-current={ navActive(ctx, "/superadmin") }><span class="sb-icon" aria-hidden="true">🛡</span>Platform</a>
						}
						<a href="/messages" class="pm-nav-link" aria-current={ navActive(ctx, "/messages") }>
							<span class="sb-icon" aria-hidden="true">✉</span>
							<span>Messages</span>
							@MessagesBadge(0)
						</a>
						<a href="/explore" aria-current={ navActive(ctx, "/explore") }><span class="sb-icon" aria-hidden="true">🔭</span>Explore</a>
						if TimeEnabled {
							<a href="/journal" aria-current={ navActive(ctx, "/journal") }><span class="sb-icon" aria-hidden="true">⏱</span>Journal</a>
						}
						<a href="/" aria-current={ navActive(ctx, "/") }><span class="sb-icon" aria-hidden="true">🏠</span>Communities</a>
						if v.CommunitySlug != "" {
							<h3 class="sidebar-group">{ v.CommunityName }</h3>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/chat") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/chat") }><span class="sb-icon" aria-hidden="true">💬</span>Chat</a>
							if AIEnabled {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/agent") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/agent") }><span class="sb-icon" aria-hidden="true">🤖</span>Agent</a>
							}
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/forum") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/forum") }><span class="sb-icon" aria-hidden="true">📋</span>Threads</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/rooms") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/rooms") }><span class="sb-icon" aria-hidden="true">🎥</span>Rooms</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/bookmarks") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/bookmarks") }><span class="sb-icon" aria-hidden="true">★</span>Bookmarks</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/todos") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/todos") }><span class="sb-icon" aria-hidden="true">☑</span>Todos</a>
							if ProjectsEnabled {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/projects") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/projects") }><span class="sb-icon" aria-hidden="true">📂</span>Projects</a>
							}
							if TimeEnabled {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/budget") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/budget") }><span class="sb-icon" aria-hidden="true">📊</span>Budget</a>
							}
							if GuestAccessEnabled && (v.Role == "admin" || v.Role == "moderator") {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/lobbies") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/lobbies") }><span class="sb-icon" aria-hidden="true">🚪</span>Lobbies</a>
							}
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/history") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/history") }><span class="sb-icon" aria-hidden="true">🕘</span>History</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/notifications") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/notifications") }><span class="sb-icon" aria-hidden="true">🔔</span>Notifications</a>
							if v.Role == "admin" {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/admin") } aria-current={ navActiveExcept(ctx, "/c/"+v.CommunitySlug+"/admin", "/c/"+v.CommunitySlug+"/admin/mail-filters") }><span class="sb-icon" aria-hidden="true">⚙</span>Admin</a>
								if MailboxEnabled {
									<a href={ templ.URL("/c/" + v.CommunitySlug + "/admin/mail-filters") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/admin/mail-filters") }><span class="sb-icon" aria-hidden="true">✉</span>Mail filters</a>
								}
								if AIEnabled {
									<a href={ templ.URL("/c/" + v.CommunitySlug + "/admin/ai") } aria-current={ navActive(ctx, "/c/"+v.CommunitySlug+"/admin/ai") }><span class="sb-icon" aria-hidden="true">🤖</span>AI</a>
								}
							}
						}
						<a href="/profile" class="sidebar-profile">
							<span class="sb-avatar" aria-hidden="true">{ initial(v.DisplayName) }</span>
							<span class="sb-name">{ v.DisplayName }</span>
						</a>
						<button class="ghost" data-on:click="@post('/logout')"><span class="sb-icon" aria-hidden="true">↩</span>Sign out</button>
					} else {
						<a href="/login"><span class="sb-icon" aria-hidden="true">→</span>Sign in</a>
						<a href="/register"><span class="sb-icon" aria-hidden="true">＋</span>Register</a>
					}
				</nav>
			</aside>
			<main>
				{ children... }
			</main>
			if v.IsAuthed {
				if v.CommunitySlug != "" {
					// Global chat event stream — opened on every page in
					// the community so a viewer on /forum still hears a
					// ping when a new chat message lands. Server emits
					// only `window.fcChatPing()` calls; chat-events.js
					// decides sound + Notification.
					<div id="chat-events-open" hidden data-init={ "@get('/c/" + v.CommunitySlug + "/chat/events', {openWhenHidden: true})" }></div>
					<script src={ "/static/chat-events.js?v=" + AssetVer("chat-events.js") } defer></script>
				}
				<div id="pm-stream-open" hidden data-init="@get('/messages/stream', {openWhenHidden: true})"></div>
				<div class="pm-toast" data-cloak data-show="$_pm_toast_text !== ''"
					data-on:animationend="$_pm_toast_text=''; $_pm_toast_href=''">
					<a class="pm-toast-link" data-attr:href="$_pm_toast_href || '/messages'">
						<span class="pm-toast-icon">✓</span>
						<span class="pm-toast-text" data-text="$_pm_toast_text"></span>
						<span class="pm-toast-cta">open</span>
					</a>
					<button class="pm-toast-close" aria-label="dismiss" data-on:click="$_pm_toast_text=''; $_pm_toast_href=''">✕</button>
				</div>
			}
			<footer class="site-footer">
				<span class="muted">Built by <a href="https://ituoga.lt" target="_blank" rel="noopener">ituoga.lt</a> and Claude</span>
			</footer>
		</body>
	</html>
}

templ Hello(communityName string) {
	@Layout("Welcome", Viewer{}) {
		<section class="card narrow">
			<h1>Welcome to { communityName }</h1>
			<p class="muted">A community space — one realtime chat channel and a forum, in one place.</p>
			<p>
				<a class="btn" href="/register">Get started</a>
				&nbsp;
				<a class="btn ghost" href="/login">Sign in</a>
			</p>
			<p class="muted">Sign-up is invite-only. Ask an admin for an invite code.</p>
		</section>
	}
}

templ Home(v Viewer) {
	@Layout("Home", v) {
		<section class="card">
			<h1>Welcome back, { v.DisplayName }</h1>
			<p class="muted">You're signed in to <strong>{ v.CommunityName }</strong>.</p>
			<p class="primary-nav">
				<a class="btn" href="/chat">Open chat</a>
				<a class="btn ghost" href="/forum">Open forum</a>
				<a class="btn ghost" href="/profile">Profile</a>
			</p>
		</section>
	}
}

templ ClockFragment(now string) {
	<div id="clock">{ now }</div>
}

templ DebugClock() {
	@Layout("Clock", Viewer{}) {
		<section class="card">
			<h1>datastar SSE clock</h1>
			<p class="muted">Ticks every second via NATS round-trip.</p>
			<div id="clock" data-init="@get('/_debug/clock/stream')">— waiting —</div>
		</section>
	}
}
