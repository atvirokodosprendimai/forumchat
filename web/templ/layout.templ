package templ

import (
	"context"
	"strings"
)

// adminAnyCtxKey is read by IsAdminOfAnyCommunity below. The auth
// middleware stores its value under the same key (matching name + type)
// so layout.templ can pick it up without importing the auth package
// (web/templ is a leaf package — see AGENTS.md §4.13).
type adminAnyCtxKeyType struct{}

var adminAnyCtxKey = adminAnyCtxKeyType{}

// IsAdminOfAnyCommunity reads the per-request flag the auth.Loader
// middleware stashes on ctx. Powers the global /inbox topbar link in
// layout.templ.
func IsAdminOfAnyCommunity(ctx context.Context) bool {
	v, _ := ctx.Value(adminAnyCtxKey).(bool)
	return v
}

// AdminAnyCtxKey is exported so the auth package can set the same key
// without an import cycle. Read by IsAdminOfAnyCommunity above.
func AdminAnyCtxKey() any { return adminAnyCtxKey }

// superAdminCtxKey mirrors adminAnyCtxKey for the platform super-admin
// flag. auth.WithSuperAdmin stashes a bool here so layout.templ can show
// the /superadmin link without importing auth (leaf package — §4.13).
type superAdminCtxKeyType struct{}

var superAdminCtxKey = superAdminCtxKeyType{}

// IsSuperAdmin reads the per-request platform super-admin flag the
// auth.Loader middleware stashes on ctx. Powers the /superadmin link.
func IsSuperAdmin(ctx context.Context) bool {
	v, _ := ctx.Value(superAdminCtxKey).(bool)
	return v
}

// SuperAdminCtxKey is exported so the auth package can set the same key
// without an import cycle. Read by IsSuperAdmin above.
func SuperAdminCtxKey() any { return superAdminCtxKey }

// communityAICtxKey carries the per-community "AI is on for THIS community"
// flag (global AI_ENABLED kill-switch AND, in SaaS, the community's master
// toggle). community.LoadCommunity stashes it; CommunityAIEnabled reads it.
// Leaf-package trick (§4.13) — community sets the same key without webtempl
// importing community.
type communityAICtxKeyType struct{}

var communityAICtxKey = communityAICtxKeyType{}

// CommunityAIEnabled reports whether AI is enabled for the community on this
// request. Unset (non-community pages) returns true so the global AIEnabled
// flag alone governs there — only /c/{slug} pages narrow it per community.
func CommunityAIEnabled(ctx context.Context) bool {
	v, ok := ctx.Value(communityAICtxKey).(bool)
	if !ok {
		return true
	}
	return v
}

// CommunityAICtxKey is exported so the community package can set the same key
// without an import cycle. Read by CommunityAIEnabled above.
func CommunityAICtxKey() any { return communityAICtxKey }

// RoleIsAdmin reports whether a role string carries admin-or-above power — i.e.
// "admin" OR the per-community "owner" (the super-admin above admin). UI gates
// must use this, not `Role == "admin"`, or a promoted owner (migration 00055)
// loses admin affordances. Mirrors auth.Role.AtLeast(RoleAdmin) on the leaf side.
func RoleIsAdmin(role string) bool { return role == "admin" || role == "owner" }

// RoleIsMod reports moderator-or-above power (moderator, admin, owner).
func RoleIsMod(role string) bool { return role == "moderator" || RoleIsAdmin(role) }

// TopNavCommunity is one entry in the top-bar community switcher — the
// communities the viewer can enter in one click. web/templ is a leaf package
// (§4.13), so the handler side builds these and stashes them on ctx under
// TopNavCommunitiesCtxKey rather than importing the community package.
type TopNavCommunity struct {
	Slug string
	Name string
}

type topNavCommunitiesCtxKeyType struct{}

var topNavCommunitiesCtxKey = topNavCommunitiesCtxKeyType{}

// TopNavCommunities reads the viewer's switchable communities stashed by the
// middleware in main.go. Powers the switcher dropdown in CommunityTopNav.
func TopNavCommunities(ctx context.Context) []TopNavCommunity {
	v, _ := ctx.Value(topNavCommunitiesCtxKey).([]TopNavCommunity)
	return v
}

// TopNavCommunitiesCtxKey is exported so a non-leaf package can stash the list
// under the same key TopNavCommunities reads from (leaf package — §4.13).
func TopNavCommunitiesCtxKey() any { return topNavCommunitiesCtxKey }

// currentPathCtxKey carries the request path so the sidebar can mark the
// active link server-side (was a client DOM-walk in nav.js). Set by a
// middleware in main.go on every request.
type currentPathCtxKeyType struct{}

var currentPathCtxKey = currentPathCtxKeyType{}

// WithCurrentPath stashes the request path on ctx for navActive.
func WithCurrentPath(ctx context.Context, p string) context.Context {
	return context.WithValue(ctx, currentPathCtxKey, p)
}

// CurrentPath returns the request path stashed by the path middleware.
func CurrentPath(ctx context.Context) string {
	p, _ := ctx.Value(currentPathCtxKey).(string)
	return p
}

// navActive returns "page" when href is the current nav location (exact or a
// path prefix), else "false" — the value of a sidebar link's aria-current.
// The CSS active state keys off [aria-current="page"]; "false" is the valid
// ARIA "not current" so non-active links stay un-highlighted.
func navActive(ctx context.Context, href string) string {
	here := strings.TrimRight(CurrentPath(ctx), "/")
	if here == "" {
		here = "/"
	}
	h := strings.TrimRight(href, "/")
	if h == "" {
		h = "/"
	}
	if here == h || (h != "/" && strings.HasPrefix(here, h+"/")) {
		return "page"
	}
	return "false"
}

// ariaPage maps a bool to the aria-current attribute value ("page" when the
// link is the current location, else the valid ARIA "false"). Lets the top-nav
// "More" dropdown summary light up when one of its hidden items is active.
func ariaPage(active bool) string {
	if active {
		return "page"
	}
	return "false"
}

// topnavMoreActive reports whether the current request path falls under one of
// the community routes tucked into the top-nav "More" dropdown, so the dropdown
// summary can show as active even while its items are collapsed.
func topnavMoreActive(ctx context.Context, slug string) bool {
	for _, seg := range []string{"bookmarks", "todos", "projects", "budget", "lobbies", "history", "notifications", "admin"} {
		if navActive(ctx, "/c/"+slug+"/"+seg) == "page" {
			return true
		}
	}
	return false
}

type Viewer struct {
	IsAuthed      bool
	DisplayName   string
	Role          string // member|moderator|admin
	CommunityName string
	CommunitySlug string // empty when no community is in scope (dashboard, login pages)
	// IsAdminOfAnyCommunity is now derived from ctx via auth.IsAdminOfAnyCommunity.
	// Field kept (unused) so existing handler-side initialisers don't break.
	IsAdminOfAnyCommunity bool
}

// themeColor picks a hex from a small accent palette using a stable
// hash of the community slug, so each community gets its own tab
// chrome tint on mobile browsers. Empty slug → the default brand color.
func themeColor(slug string) string {
	palette := []string{
		"#6366f1", // indigo (default brand)
		"#8b5cf6", // violet
		"#06b6d4", // cyan
		"#10b981", // emerald
		"#f59e0b", // amber
		"#ef4444", // rose
		"#ec4899", // pink
		"#3b82f6", // blue
	}
	if slug == "" {
		return palette[0]
	}
	var h uint32 = 2166136261
	for i := 0; i < len(slug); i++ {
		h ^= uint32(slug[i])
		h *= 16777619
	}
	return palette[int(h%uint32(len(palette)))]
}

// initial returns the first visible rune of a display name, uppercased,
// for the sidebar avatar placeholder. Empty input → "?".
func initial(s string) string {
	for _, r := range s {
		if r == ' ' || r == '\t' {
			continue
		}
		if r >= 'a' && r <= 'z' {
			r = r - 'a' + 'A'
		}
		return string(r)
	}
	return "?"
}

// ProjectsEnabled is the instance-level Projects feature flag. Set at boot
// in main.go from config.ProjectsEnabled. Read directly by layout.templ
// so no per-handler Viewer plumbing is required.
var ProjectsEnabled bool

// AIEnabled is the instance-level Agent feature flag. Set at boot in main.go
// from config.AIEnabled. Toggles the "Agent" nav link + the admin "AI"
// sublink and gates the /c/{slug}/agent routes registered in main.
var AIEnabled bool

// RAGEnabled is the instance-level semantic-search feature flag. Set at boot in
// main.go from config.RAGEnabled. Toggles the "Reindex" buttons on the
// super-admin dashboard and the per-community admin page.
var RAGEnabled bool

// GuestAccessEnabled — instance-level Lobbies flag. Toggles the
// sidebar menu item and gates the host-side routes registered in main.
var GuestAccessEnabled bool

// MailboxEnabled — instance-level IMAP mailbox flag. Toggles the
// global /inbox sidebar link (further gated by viewer's admin-of-any-
// community status) and the poll worker.
var MailboxEnabled bool

// WebhooksEnabled — instance-level webhooks flag. Gates the public
// /hooks/{token} route, the per-community admin webhooks page + its link,
// and the outbound relay hook.
var WebhooksEnabled bool

// TimeEnabled — instance-level time-accounting flag. Toggles both the
// per-community "Budget" link and the global personal "Journal" link, and
// gates the route mounts in main.go. Tables always exist so flipping the
// flag never needs a schema migration.
var TimeEnabled bool

// OpenRegistration mirrors config.OpenRegistration (set at boot in main.go).
// Read by the public LandingPage (landing.templ) so the marketing CTA copy
// matches the instance's signup mode — self-serve vs invite-only — without
// threading the flag through the dashboard handler.
var OpenRegistration bool

// Version is the build version shown in the footer. It defaults to "dev" for
// local builds and is overridden at link time on tagged CI builds via
// -ldflags "-X github.com/atvirokodosprendimai/forumchat/web/templ.Version=<tag>".
// web/templ is a leaf package (AGENTS.md §4.13), so the version lives here
// directly rather than being threaded through every Layout call site.
var Version = "dev"

