package templ

import "context"

// adminAnyCtxKey is read by IsAdminOfAnyCommunity below. The auth
// middleware stores its value under the same key (matching name + type)
// so layout.templ can pick it up without importing the auth package
// (web/templ is a leaf package — see AGENTS.md §4.13).
type adminAnyCtxKeyType struct{}

var adminAnyCtxKey = adminAnyCtxKeyType{}

// IsAdminOfAnyCommunity reads the per-request flag the auth.Loader
// middleware stashes on ctx. Powers the global /inbox topbar link in
// layout.templ.
func IsAdminOfAnyCommunity(ctx context.Context) bool {
	v, _ := ctx.Value(adminAnyCtxKey).(bool)
	return v
}

// AdminAnyCtxKey is exported so the auth package can set the same key
// without an import cycle. Read by IsAdminOfAnyCommunity above.
func AdminAnyCtxKey() any { return adminAnyCtxKey }

type Viewer struct {
	IsAuthed      bool
	DisplayName   string
	Role          string // member|moderator|admin
	CommunityName string
	CommunitySlug string // empty when no community is in scope (dashboard, login pages)
	// IsAdminOfAnyCommunity is now derived from ctx via auth.IsAdminOfAnyCommunity.
	// Field kept (unused) so existing handler-side initialisers don't break.
	IsAdminOfAnyCommunity bool
}

// themeColor picks a hex from a small accent palette using a stable
// hash of the community slug, so each community gets its own tab
// chrome tint on mobile browsers. Empty slug → the default brand color.
func themeColor(slug string) string {
	palette := []string{
		"#6366f1", // indigo (default brand)
		"#8b5cf6", // violet
		"#06b6d4", // cyan
		"#10b981", // emerald
		"#f59e0b", // amber
		"#ef4444", // rose
		"#ec4899", // pink
		"#3b82f6", // blue
	}
	if slug == "" {
		return palette[0]
	}
	var h uint32 = 2166136261
	for i := 0; i < len(slug); i++ {
		h ^= uint32(slug[i])
		h *= 16777619
	}
	return palette[int(h%uint32(len(palette)))]
}

// initial returns the first visible rune of a display name, uppercased,
// for the sidebar avatar placeholder. Empty input → "?".
func initial(s string) string {
	for _, r := range s {
		if r == ' ' || r == '\t' {
			continue
		}
		if r >= 'a' && r <= 'z' {
			r = r - 'a' + 'A'
		}
		return string(r)
	}
	return "?"
}

// ProjectsEnabled is the instance-level Projects feature flag. Set at boot
// in main.go from config.ProjectsEnabled. Read directly by layout.templ
// so no per-handler Viewer plumbing is required.
var ProjectsEnabled bool

// GuestAccessEnabled — instance-level Lobbies flag. Toggles the
// sidebar menu item and gates the host-side routes registered in main.
var GuestAccessEnabled bool

// MailboxEnabled — instance-level IMAP mailbox flag. Toggles the
// global /inbox sidebar link (further gated by viewer's admin-of-any-
// community status) and the poll worker.
var MailboxEnabled bool

// InitialSignals — global signal bag rendered on every page.
// Every data-bind / data-on-click POST sees these as their starting state.
const InitialSignals = `{
	"email":"",
	"password":"",
	"invite_code":"",
	"display_name":"",
	"avatar_url":"",
	"subject":"",
	"body":"",
	"quoted_post_id":"",
	"reply_quote_label":"",
	"reply_to_id":"",
	"max_uses":"",
	"cleanup_chat":false,
	"cleanup_threads":false,
	"cleanup_posts":false,
	"ban_hours":0,
	"bm_open_msg":"",
	"bm_new_title":"",
	"bm_new_category":"",
	"bm_new_note":"",
	"bm_title":"",
	"bm_category":"",
	"bm_from":"",
	"bm_to":"",
	"image_data":"",
	"rename_open":false,
	"new_subject":"",
	"cc_name":"",
	"cc_slug":"",
	"cc_member_email":"",
	"am_email":"",
	"am_role":"member",
	"am_send_email":true,
	"notif_digest_minutes":0,
	"share_message":"",
	"join_password":"",
	"todo_open_source":"",
	"todo_title":"",
	"todo_category":"",
	"todo_note":"",
	"pm_open_to_user":"",
	"pm_open_to_name":"",
	"pm_to_user":"",
	"pm_body":"",
	"pm_source_community_id":"",
	"pm_source_chat_id":"",
	"pm_send_body":"",
	"pm_toast_text":"",
	"pm_toast_href":"",
	"rooms_chat_body":"",
	"rooms_target":"",
	"rooms_new_name":"",
	"rooms_admin_open":false,
	"rooms_rename_open":false,
	"rooms_member_count":0,
	"rooms_room_name":"",
	"rooms_am_admin":false,
	"rooms_invite_emails":"",
	"nav_open":false,
	"mention_query":"",
	"mention_open":false,
	"inbox_community":"",
	"next_cursor":"",
	"attach_open":false,
	"attach_addr":"",
	"attach_kind":"address",
	"attach_community":"",
	"attach_to_issue":false,
	"mf_kind":"address",
	"mf_pattern":"",
	"mf_to_issue":false,
	"inbox_q":"",
	"inbox_pending":0,
	"move_project_id":"",
	"move_category":"common",
	"toast_text":""
}`

templ Layout(title string, v Viewer) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width,initial-scale=1"/>
			<title>{ title } — forumchat</title>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
				<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
				<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=JetBrains+Mono:wght@400;600&display=swap"/>
				<link rel="stylesheet" href={ "/static/app.css?v=" + AssetVer("app.css") }/>
				<link rel="manifest" href={ "/static/manifest.webmanifest?v=" + AssetVer("manifest.webmanifest") }/>
				<link rel="icon" type="image/svg+xml" href="/static/icon.svg"/>
				<link rel="apple-touch-icon" href="/static/icon-192.png"/>
				<meta name="theme-color" content={ themeColor(v.CommunitySlug) }/>
				<meta name="mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-capable" content="yes"/>
				<meta name="apple-mobile-web-app-title" content="forumchat"/>
			<script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.2/bundles/datastar.js"></script>
			<script src={ "/static/paste.js?v=" + AssetVer("paste.js") } defer></script>
			<script src={ "/static/mention.js?v=" + AssetVer("mention.js") } defer></script>
		</head>
		<body data-signals={ InitialSignals }
			data-init="document.querySelectorAll('[data-cloak]').forEach(e=>e.removeAttribute('data-cloak'))">
			<script src={ "/static/nav.js?v=" + AssetVer("nav.js") } defer></script>
			<header class="topbar">
				<button class="topbar-hamburger" aria-label="Toggle navigation"
					type="button" data-nav-toggle>
					<span class="hamburger-bar"></span>
					<span class="hamburger-bar"></span>
					<span class="hamburger-bar"></span>
				</button>
				<a href="/" class="brand">forumchat</a>
			</header>
			<div class="nav-overlay" data-nav-overlay></div>
			<aside class="sidebar">
				<a href="/" class="sidebar-brand">forumchat</a>
				<nav>
					if v.IsAuthed {
						if v.CommunitySlug != "" {
							<h3 class="sidebar-group">{ v.CommunityName }</h3>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/chat") }><span class="sb-icon" aria-hidden="true">💬</span>Chat</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/forum") }><span class="sb-icon" aria-hidden="true">📋</span>Forum</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/rooms") }><span class="sb-icon" aria-hidden="true">🎥</span>Rooms</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/bookmarks") }><span class="sb-icon" aria-hidden="true">★</span>Bookmarks</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/todos") }><span class="sb-icon" aria-hidden="true">☑</span>Todos</a>
							if ProjectsEnabled {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/projects") }><span class="sb-icon" aria-hidden="true">📂</span>Projects</a>
							}
							if GuestAccessEnabled && (v.Role == "admin" || v.Role == "moderator") {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/lobbies") }><span class="sb-icon" aria-hidden="true">🚪</span>Lobbies</a>
							}
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/history") }><span class="sb-icon" aria-hidden="true">🕘</span>History</a>
							<a href={ templ.URL("/c/" + v.CommunitySlug + "/notifications") }><span class="sb-icon" aria-hidden="true">🔔</span>Notifications</a>
							if v.Role == "admin" {
								<a href={ templ.URL("/c/" + v.CommunitySlug + "/admin") }><span class="sb-icon" aria-hidden="true">⚙</span>Admin</a>
								if MailboxEnabled {
									<a href={ templ.URL("/c/" + v.CommunitySlug + "/admin/mail-filters") }><span class="sb-icon" aria-hidden="true">✉</span>Mail filters</a>
								}
							}
						}
						<h3 class="sidebar-group">You</h3>
						if MailboxEnabled && IsAdminOfAnyCommunity(ctx) {
							<a href="/inbox"><span class="sb-icon" aria-hidden="true">📥</span>Inbox</a>
						}
						<a href="/messages" class="pm-nav-link">
							<span class="sb-icon" aria-hidden="true">✉</span>
							<span>Messages</span>
							@MessagesBadge(0)
						</a>
						<a href="/explore"><span class="sb-icon" aria-hidden="true">🔭</span>Explore</a>
						<a href="/"><span class="sb-icon" aria-hidden="true">🏠</span>Communities</a>
						<a href="/profile" class="sidebar-profile">
							<span class="sb-avatar" aria-hidden="true">{ initial(v.DisplayName) }</span>
							<span class="sb-name">{ v.DisplayName }</span>
						</a>
						<button class="ghost" data-on:click="@post('/logout')"><span class="sb-icon" aria-hidden="true">↩</span>Sign out</button>
					} else {
						<a href="/login"><span class="sb-icon" aria-hidden="true">→</span>Sign in</a>
						<a href="/register"><span class="sb-icon" aria-hidden="true">＋</span>Register</a>
					}
				</nav>
			</aside>
			<main>
				{ children... }
			</main>
			if v.IsAuthed {
				<div id="pm-stream-open" hidden data-init="@get('/messages/stream', {openWhenHidden: true})"></div>
				<div class="pm-toast" data-cloak data-show="$pm_toast_text !== ''"
					data-on:animationend="$pm_toast_text=''; $pm_toast_href=''">
					<a class="pm-toast-link" data-attr:href="$pm_toast_href || '/messages'">
						<span class="pm-toast-icon">✓</span>
						<span class="pm-toast-text" data-text="$pm_toast_text"></span>
						<span class="pm-toast-cta">open</span>
					</a>
					<button class="pm-toast-close" aria-label="dismiss" data-on:click="$pm_toast_text=''; $pm_toast_href=''">✕</button>
				</div>
			}
			<footer class="site-footer">
				<span class="muted">Built by <a href="https://ituoga.lt" target="_blank" rel="noopener">ituoga.lt</a> and Claude</span>
			</footer>
		</body>
	</html>
}

templ Hello(communityName string) {
	@Layout("Welcome", Viewer{}) {
		<section class="card narrow">
			<h1>Welcome to { communityName }</h1>
			<p class="muted">A community space — one realtime chat channel and a forum, in one place.</p>
			<p>
				<a class="btn" href="/register">Get started</a>
				&nbsp;
				<a class="btn ghost" href="/login">Sign in</a>
			</p>
			<p class="muted">Sign-up is invite-only. Ask an admin for an invite code.</p>
		</section>
	}
}

templ Home(v Viewer) {
	@Layout("Home", v) {
		<section class="card">
			<h1>Welcome back, { v.DisplayName }</h1>
			<p class="muted">You're signed in to <strong>{ v.CommunityName }</strong>.</p>
			<p class="primary-nav">
				<a class="btn" href="/chat">Open chat</a>
				<a class="btn ghost" href="/forum">Open forum</a>
				<a class="btn ghost" href="/profile">Profile</a>
			</p>
		</section>
	}
}

templ ClockFragment(now string) {
	<div id="clock">{ now }</div>
}

templ DebugClock() {
	@Layout("Clock", Viewer{}) {
		<section class="card">
			<h1>datastar SSE clock</h1>
			<p class="muted">Ticks every second via NATS round-trip.</p>
			<div id="clock" data-init="@get('/_debug/clock/stream')">— waiting —</div>
		</section>
	}
}
