package templ

import "time"

type AdminInvite struct {
	Code       string
	MaxUsesStr string // "unlimited" or "3"
	UsesCount  int
	ExpiresAt  time.Time
	CreatedAt  time.Time
}

type AdminMember struct {
	MembershipID string
	UserID       string
	Email        string
	// DisplayName is the effective name shown to everyone (admin override if
	// set, else the member's own name). RealName is the member's own
	// self-chosen name; AdminNick is the admin override ("" = none).
	DisplayName string
	RealName    string
	AdminNick   string
	Role        string
	IsBanned    bool
	BannedUntil *time.Time
	IsApproved  bool
	CreatedAt   time.Time
	JoinReason  string // "why do you want to join?" note, shown in the pending queue
}

type AdminReport struct {
	ID           string
	ReporterName string
	ReportedName string
	Reason       string
	When         string
}

type AdminPageData struct {
	Viewer   Viewer
	IsPublic bool
	Pending  []AdminMember
	Members  []AdminMember
	Invites  []AdminInvite
	Reports  []AdminReport
	// AgentRatePerUserMin / AgentRatePerCommunityMin seed the AI prompt
	// rate-limit form (per minute, 0 = unlimited).
	AgentRatePerUserMin      int
	AgentRatePerCommunityMin int
}

// agentLimitSignals seeds the rate-limit number inputs with the community's
// current values, merged over InitialSignals on page load.
func agentLimitSignals(d AdminPageData) string {
	return `{"agent_rate_user":` + itoa(d.AgentRatePerUserMin) +
		`,"agent_rate_community":` + itoa(d.AgentRatePerCommunityMin) + `}`
}

templ AdminPage(d AdminPageData) {
	@Layout("Admin", d.Viewer) {
		<section>
			@PageHeader("Admin", "") {
			}
			<p class="muted"><a href={ templ.URL("/c/" + d.Viewer.CommunitySlug + "/admin") }>refresh</a></p>

			<div class="admin-cards">
			<section class="card narrow">
				<h2>Visibility</h2>
				if d.IsPublic {
					<p>This community is <strong>public</strong> — it appears on <a href="/explore">/explore</a> and signed-in users can request to join.</p>
					<button class="ghost" data-on:click={ "@post('/c/" + d.Viewer.CommunitySlug + "/admin/toggle-public')" }>Make private</button>
				} else {
					<p>This community is <strong>private</strong> — invite-only.</p>
					<button data-on:click={ "@post('/c/" + d.Viewer.CommunitySlug + "/admin/toggle-public')" }>Make public</button>
				}
			</section>

			if AIEnabled && CommunityAIEnabled(ctx) {
				<section class="card narrow">
					<h2>AI agents</h2>
					<p class="muted">Create and configure the AI agents members can chat with — each with its own model and system prompt.</p>
					<a class="button" href={ templ.URL("/c/" + d.Viewer.CommunitySlug + "/admin/ai") }>Manage AI agents →</a>
					<div data-signals={ agentLimitSignals(d) }></div>
					<h3>Prompt rate limits</h3>
					<p class="muted">Cap how often members can trigger agents, in requests per minute. <strong>0 = unlimited.</strong> Platform super-admins are never limited. Changes apply immediately.</p>
					<div class="field">
						<label for="agent_rate_user">Per member · per minute</label>
						<input id="agent_rate_user" type="number" min="0" step="1" data-bind="agent_rate_user"/>
					</div>
					<div class="field">
						<label for="agent_rate_community">Whole community · per minute</label>
						<input id="agent_rate_community" type="number" min="0" step="1" data-bind="agent_rate_community"/>
					</div>
					<button data-on:click={ "@post('/c/" + d.Viewer.CommunitySlug + "/admin/ai/limits')" }>Save limits</button>
					<div id="ai-limits-result" aria-live="polite"></div>
				</section>
			}

			if MailboxEnabled {
				<section class="card narrow">
					<h2>Mail filters</h2>
					<p class="muted">Route inbound email into this community — rules match the sender address and post matching mail to the inbox.</p>
					<a class="button" href={ templ.URL("/c/" + d.Viewer.CommunitySlug + "/admin/mail-filters") }>Manage mail filters →</a>
				</section>
			}

			if WebhooksEnabled {
				<section class="card narrow">
					<h2>Webhooks</h2>
					<p class="muted">Let external systems (GitHub, CI, Matrix bridges, anything that POSTs JSON) post into this community as a bot, or relay chat out to Slack/Discord.</p>
					<a class="button" href={ templ.URL("/c/" + d.Viewer.CommunitySlug + "/admin/webhooks") }>Manage webhooks →</a>
				</section>
			}

			if ConnectorsEnabled {
				<section class="card narrow">
					<h2>Chat bots</h2>
					<p class="muted">Connect an external worker (a custom chat app, a bot, an e-shop widget) over a signed realtime stream. It joins channels and acts as a regular member — and can be granted moderation powers.</p>
					<a class="button" href={ templ.URL("/c/" + d.Viewer.CommunitySlug + "/admin/connectors") }>Manage chat bots →</a>
				</section>
			}

			if RAGEnabled {
				<section class="card narrow">
					<h2>Semantic index</h2>
					<p class="muted">Rebuild this community’s vector index — drops its current embeddings, then re-queues all of its public content (chat, threads, issues, discussions, shared AI answers). The embed worker processes the queue in the background.</p>
					<div id="admin-reindex-result"></div>
					<button class="ghost" data-on:click={ "if(confirm('Reindex this community? Drops its vectors and re-embeds all its public content in the background.')){@post('/c/" + d.Viewer.CommunitySlug + "/admin/reindex')}" }>Reindex this community</button>
				</section>
			}

			<section class="card narrow">
				<h2>Add member by email</h2>
				<p class="muted">Existing accounts get pre-approved instantly. New emails get a join URL — tick the box below to send it by email.</p>
				<div id="am-result"></div>
				<div class="field">
					<label>Email</label>
					<input type="email" data-bind="am_email" placeholder="alice@acme.com"/>
				</div>
				<div class="field">
					<label>Role</label>
					<select data-bind="am_role">
						<option value="member">member</option>
						<option value="moderator">moderator</option>
					</select>
				</div>
				<label class="check-row">
					<input type="checkbox" data-bind="am_send_email"/>
					<span>Email them the join link</span>
				</label>
				<button data-on:click={ "@post('/c/" + d.Viewer.CommunitySlug + "/admin/add-member')" }>Add</button>
			</section>
			</div>

			<h2>Reports ({ itoa(len(d.Reports)) })</h2>
			<div id="admin-reports">
				@AdminReports(d.Viewer.CommunitySlug, d.Reports)
			</div>

			<h2>Pending join requests ({ itoa(len(d.Pending)) })</h2>
			<div id="admin-pending">
				@AdminPending(d.Viewer.CommunitySlug, d.Pending)
			</div>

			<h2>Members ({ itoa(len(d.Members)) })</h2>
			<div id="admin-members">
				@AdminMembers(d.Viewer.CommunitySlug, d.Members)
			</div>

			<h2>Invite codes</h2>
			<div id="admin-invite-new" class="card narrow">
				<h3>New invite</h3>
				<div id="admin-invite-error" class="error"></div>
				<div class="field">
					<label>Max uses (blank = unlimited)</label>
					<input type="number" data-bind="max_uses" min="1" placeholder="e.g. 5 — leave blank for Discord-style unlimited"/>
				</div>
				<button data-on:click={ "@post('/c/" + d.Viewer.CommunitySlug + "/admin/invite')" }>Create code</button>
			</div>
			<div id="admin-invites">
				@AdminInvites(d.Viewer.CommunitySlug, d.Invites)
			</div>
		</section>
	}
}

// AdminReindexResult is the morph target for the per-community "Reindex" button.
templ AdminReindexResult(msg string) {
	<div id="admin-reindex-result"><p class="muted">{ msg }</p></div>
}

// AdminAgentLimitsSaved is the morph target for the "Save limits" button.
templ AdminAgentLimitsSaved(perUser, perCommunity int) {
	<div id="ai-limits-result">
		<p class="ok-text">Saved ✓ — { agentLimitSummary(perUser, perCommunity) }</p>
	</div>
}

// agentLimitSummary renders a human sentence for the saved limits.
func agentLimitSummary(perUser, perCommunity int) string {
	user := "unlimited per member"
	if perUser > 0 {
		user = itoa(perUser) + "/min per member"
	}
	comm := "unlimited community-wide"
	if perCommunity > 0 {
		comm = itoa(perCommunity) + "/min community-wide"
	}
	return user + ", " + comm + "."
}

templ AdminReports(slug string, rows []AdminReport) {
	<div id="admin-reports">
		if len(rows) == 0 {
			<p class="muted">No open reports.</p>
		}
		<ul class="thread-list">
			for _, rep := range rows {
				<li>
					<strong>{ rep.ReportedName }</strong>
					<span class="muted">reported by { rep.ReporterName } · { rep.When }</span>
					<div class="report-reason">{ rep.Reason }</div>
					<div style="margin-top:.4rem">
						<button class="ghost"
							data-on:click={ "@post('/c/" + slug + "/admin/report/resolve?id=" + rep.ID + "')" }>Mark resolved</button>
					</div>
				</li>
			}
		</ul>
	</div>
}

templ AdminPending(slug string, rows []AdminMember) {
	<div id="admin-pending">
		if len(rows) == 0 {
			<p class="muted">No pending requests.</p>
		}
		<ul class="thread-list">
			for _, m := range rows {
				<li>
					<strong>{ m.DisplayName }</strong> ({ m.Email }) · <span class="muted">{ fmtTime(m.CreatedAt) }</span>
					if m.JoinReason != "" {
						<blockquote class="admin-join-reason">{ m.JoinReason }</blockquote>
					}
					<div style="margin-top:.4rem">
						<button data-on:click={ "@post('/c/" + slug + "/admin/approve?id=" + m.MembershipID + "')" }>Approve</button>
						<button class="ghost"
							data-on:click={ "@post('/c/" + slug + "/admin/reject?id=" + m.MembershipID + "')" }>Reject</button>
					</div>
				</li>
			}
		</ul>
	</div>
}

templ AdminMembers(slug string, rows []AdminMember) {
	<div id="admin-members">
		<ul class="thread-list">
			for _, m := range rows {
				<li>
					<strong>{ m.DisplayName }</strong> ({ m.Email }) ·
					<span class="muted">{ m.Role } · joined { fmtTime(m.CreatedAt) }</span>
					if m.AdminNick != "" {
						<span class="muted"> · alias for “{ m.RealName }”</span>
					}
					if m.IsBanned {
						<span class="error"> · BANNED</span>
					}
					<div style="margin-top:.4rem" class="primary-nav">
						@NickForm(slug, m)
						if !m.IsBanned {
							@BanForm(slug, m.MembershipID)
						} else {
							<button data-on:click={ "@post('/c/" + slug + "/admin/unban?id=" + m.MembershipID + "')" }>Unban</button>
						}
						@RemoveForm(slug, m.MembershipID)
					</div>
				</li>
			}
		</ul>
	</div>
}

// NickForm lets an admin set or clear a per-community display-name override
// for a member. The override is what everyone else sees (chat, forum, roster,
// @mentions); the member's own name stays as the fallback. Mirrors the
// per-row data-signals + hardcoded-id pattern of BanForm/RemoveForm — only
// one form is edited at a time, so the shared admin_nick signal is reset on
// open and the placeholder shows the current effective name.
templ NickForm(slug string, m AdminMember) {
	<details data-signals="{admin_nick:''}">
		<summary class="link-button" style="cursor:pointer" data-on:click="$admin_nick=''">
			if m.AdminNick != "" {
				Edit alias…
			} else {
				Set alias…
			}
		</summary>
		<div style="margin-top:.5rem">
			<p class="muted" style="margin:.25rem 0">
				Shown to everyone in chat, forum, roster and @mentions. Their own name
				(<strong>{ m.RealName }</strong>) is kept and used when no alias is set.
			</p>
			<input type="text" data-bind="admin_nick" placeholder={ m.DisplayName } maxlength="60" style="width:14em"/>
			<button class="ghost" style="margin-top:.4rem"
				data-on:click={ "@post('/c/" + slug + "/admin/set-nick?id=" + m.MembershipID + "')" }>Save alias</button>
			if m.AdminNick != "" {
				<button class="ghost danger" style="margin-top:.4rem"
					data-on:click={ "$admin_nick=''; @post('/c/" + slug + "/admin/set-nick?id=" + m.MembershipID + "')" }>Clear alias</button>
			}
		</div>
	</details>
}

// RemoveForm — second-step purge picker for "remove from community".
// Same details/summary affordance as BanForm so the dangerous action
// stays hidden behind a click, with explicit content-purge checkboxes
// before the destructive confirm.
templ RemoveForm(slug, membershipID string) {
	<details>
		<summary class="link-button" style="cursor:pointer">Remove…</summary>
		<div style="margin-top:.5rem" data-signals={ "{cleanup_chat:false,cleanup_threads:false,cleanup_posts:false}" }>
			<p class="muted" style="margin:.25rem 0">Deletes their membership in this community. The user account itself stays — they can rejoin with a fresh invite.</p>
			<label><input type="checkbox" data-bind="cleanup_chat"/> also delete their chat messages</label><br/>
			<label><input type="checkbox" data-bind="cleanup_threads"/> also delete their forum threads</label><br/>
			<label><input type="checkbox" data-bind="cleanup_posts"/> also delete their forum replies</label><br/>
			<button class="ghost danger" style="margin-top:.4rem"
				data-on:click={ "@post('/c/" + slug + "/admin/remove?id=" + membershipID + "')" }>Confirm remove</button>
		</div>
	</details>
}

templ BanForm(slug, membershipID string) {
	<details>
		<summary class="link-button" style="cursor:pointer">Ban…</summary>
		<div style="margin-top:.5rem" data-signals={ "{cleanup_chat:false,cleanup_threads:false,cleanup_posts:false,ban_hours:0}" }>
			<label><input type="checkbox" data-bind="cleanup_chat"/> delete chat messages</label><br/>
			<label><input type="checkbox" data-bind="cleanup_threads"/> delete forum threads</label><br/>
			<label><input type="checkbox" data-bind="cleanup_posts"/> delete forum replies</label><br/>
			<label>Duration (hours, 0 = permanent): <input type="number" data-bind="ban_hours" min="0" style="width:6em"/></label><br/>
			<button class="ghost" style="margin-top:.4rem"
				data-on:click={ "@post('/c/" + slug + "/admin/ban?id=" + membershipID + "')" }>Confirm ban</button>
		</div>
	</details>
}

templ AdminInvites(slug string, rows []AdminInvite) {
	<div id="admin-invites">
		if len(rows) == 0 {
			<div class="empty-state">
				<div class="empty-icon" aria-hidden="true">🔑</div>
				<p><strong>No invite codes yet.</strong></p>
				<p>Create one above to let new members join.</p>
			</div>
		}
		<ul class="invite-list">
			for _, ic := range rows {
				<li class="invite-card">
					<div class="invite-card-main">
						<code class="invite-code">{ ic.Code }</code>
						<div class="invite-card-meta">
							<span class="invite-stat"><span class="invite-stat-num">{ itoa(ic.UsesCount) }</span> used</span>
							<span class="invite-stat"><span class="invite-stat-num">{ ic.MaxUsesStr }</span> cap</span>
							<span class="invite-stat muted">expires { fmtTime(ic.ExpiresAt) }</span>
						</div>
					</div>
					<button class="ghost"
						data-on:click={ "@post('/c/" + slug + "/admin/invite/revoke?code=" + ic.Code + "')" }>Revoke</button>
				</li>
			}
		</ul>
	</div>
}

templ AdminInviteCreated(code string) {
	<div id="admin-invite-error" class="success">Created: <code>{ code }</code></div>
}

func itoa(n int) string {
	if n == 0 {
		return "0"
	}
	negative := n < 0
	if negative {
		n = -n
	}
	var b [20]byte
	i := len(b)
	for n > 0 {
		i--
		b[i] = byte('0' + n%10)
		n /= 10
	}
	if negative {
		i--
		b[i] = '-'
	}
	return string(b[i:])
}
