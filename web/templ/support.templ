package templ

import (
	"time"

	"github.com/atvirokodosprendimai/forumchat/internal/render"
)

// SupportInboxEnabled is the instance-level flag for the hidden support
// inbox. Set at boot in main.go from config.SupportInboxSlug != "".
// Read by layout.templ to show the global "Report issue" nav link.
var SupportInboxEnabled bool

// SupportReportRow is one support report. Reporter is empty in the
// reporter's own list and set (the author's name) in the super-admin
// inbox so triage shows who filed it.
type SupportReportRow struct {
	IssueID       string
	Title         string
	Status        string
	Reporter      string
	CreatedAtUnix int64
	UpdatedAtUnix int64
}

// SupportCommentView is one message in a report's conversation.
type SupportCommentView struct {
	AuthorName    string
	BodyHTML      string
	CreatedAtUnix int64
	IsMine        bool // authored by the viewing reporter ("You")
}

// SupportReportPageData drives GET /report-issue.
type SupportReportPageData struct {
	Viewer  Viewer
	Reports []SupportReportRow
}

// SupportInboxPageData drives the super-admin GET /support-inbox — ALL
// reports across every tenant.
type SupportInboxPageData struct {
	Viewer  Viewer
	Reports []SupportReportRow
}

// SupportReportDetailData drives GET /report-issue/{iid}. IsAdmin shows
// the super-admin status control.
type SupportReportDetailData struct {
	Viewer   Viewer
	Report   SupportReportRow
	BodyHTML string
	Comments []SupportCommentView
	IsAdmin  bool
}

// SupportReportPage is the composer + the caller's own past reports.
templ SupportReportPage(d SupportReportPageData) {
	@Layout("Report an issue", d.Viewer) {
		<section class="support" data-signals="{report_title:'', report_body:''}">
			<header class="support-head">
				<h1>🛟 Report an issue</h1>
				<p class="muted">Send a problem or request to the team. Only the platform team can see this — other members can’t. We’ll reply right here.</p>
			</header>
			@SupportFlash("", false)
			<form class="support-form card" data-on:submit__prevent="@post('/report-issue')">
				<label class="support-label" for="support-subject">Subject</label>
				<input
					id="support-subject"
					class="support-input"
					type="text"
					maxlength="200"
					placeholder="Short summary"
					data-bind="report_title"
				/>
				<label class="support-label" for="support-body">Details</label>
				<textarea
					id="support-body"
					class="support-textarea"
					rows="5"
					placeholder="What happened? Steps you took, what you expected, links to screenshots…"
					data-bind="report_body"
				></textarea>
				<div class="support-actions">
					<button class="support-send" type="submit" data-attr:disabled="$report_title.trim() === ''">Send report</button>
				</div>
			</form>
			<h2 class="support-subhead">Your reports</h2>
			@SupportMyReports(d.Reports)
		</section>
	}
}

// SupportInboxPage is the super-admin triage view: every report across
// all tenants. Reuses the report list (rows link to the shared detail
// page, which a super-admin may open for any report).
templ SupportInboxPage(d SupportInboxPageData) {
	@Layout("Support inbox", d.Viewer) {
		<section class="support">
			@PageHeader("📨 Support inbox", "Every report filed from the “Report issue” button, across all communities. Only platform admins see this.") {
			}
			@SupportMyReports(d.Reports)
		</section>
	}
}

// SupportMyReports is the report list. Stable id so the create handler can
// outer-morph it after a new report lands. Reused by the reporter's own
// page and the super-admin inbox (rows carry Reporter only in the latter).
templ SupportMyReports(reports []SupportReportRow) {
	<div id="support-my-reports" class="support-reports">
		if len(reports) == 0 {
			<p class="empty muted">No reports yet.</p>
		} else {
			<ul class="support-report-list">
				for _, rep := range reports {
					<li>
						<a class="support-report" href={ supportReportURL(rep.IssueID) }>
							<span class={ "support-status", "status-" + rep.Status }>{ supportStatusLabel(rep.Status) }</span>
							<span class="support-report-title">{ rep.Title }</span>
							if rep.Reporter != "" {
								<span class="support-report-by">{ rep.Reporter }</span>
							}
							<time class="support-report-time" datetime={ supportRFC(rep.UpdatedAtUnix) }>{ supportShort(rep.UpdatedAtUnix) }</time>
						</a>
					</li>
				}
			</ul>
		}
	</div>
}

// SupportFlash is the result banner (ok / error). Stable id, always
// present so the morph target exists even before the first action.
templ SupportFlash(msg string, isErr bool) {
	<div id="support-flash" class={ "support-flash", templ.KV("is-error", isErr && msg != ""), templ.KV("is-ok", !isErr && msg != "") } aria-live="polite">
		if msg != "" {
			<p>{ msg }</p>
		}
	</div>
}

// SupportReportDetailPage shows one report + its conversation + reply box.
templ SupportReportDetailPage(d SupportReportDetailData) {
	@Layout("Report · "+d.Report.Title, d.Viewer) {
		<section class="support support-detail" data-signals="{report_reply:''}">
			<a class="support-back" href={ supportBackURL(d.IsAdmin) }>{ supportBackLabel(d.IsAdmin) }</a>
			<header class="support-head">
				@SupportStatusBar(d.Report, d.IsAdmin)
				<h1>{ d.Report.Title }</h1>
				<p class="muted support-report-time">Opened { supportShort(d.Report.CreatedAtUnix) }</p>
			</header>
			<div class="support-body card">@templ.Raw(render.RichHTML(d.BodyHTML))</div>
			<h2 class="support-subhead">Conversation</h2>
			@SupportThread(d.Comments)
			<form class="support-form card" data-on:submit__prevent={ "@post('/report-issue/" + d.Report.IssueID + "/reply')" }>
				<label class="support-label" for="support-reply">Add a reply</label>
				<textarea
					id="support-reply"
					class="support-textarea"
					rows="3"
					placeholder="Reply to the team…"
					data-bind="report_reply"
				></textarea>
				<div class="support-actions">
					<button class="support-send" type="submit" data-attr:disabled="$report_reply.trim() === ''">Send reply</button>
				</div>
			</form>
		</section>
	}
}

// SupportThread is the report conversation. Stable id so a reply can
// outer-morph it.
templ SupportThread(comments []SupportCommentView) {
	<div id="support-thread" class="support-thread">
		if len(comments) == 0 {
			<p class="empty muted">No replies yet.</p>
		} else {
			for _, c := range comments {
				<div class={ "support-msg", templ.KV("mine", c.IsMine) }>
					<div class="support-msg-head">
						<span class="support-msg-author">{ supportAuthor(c) }</span>
						<time datetime={ supportRFC(c.CreatedAtUnix) }>{ supportShort(c.CreatedAtUnix) }</time>
					</div>
					<div class="support-msg-body">@templ.Raw(render.RichHTML(c.BodyHTML))</div>
				</div>
			}
		}
	</div>
}

// SupportStatusBar shows the status pill and, for super-admins, buttons
// to move the report to any other status. Stable id so PostStatus can
// outer-morph it after a change.
templ SupportStatusBar(rep SupportReportRow, isAdmin bool) {
	<div id="support-status-bar" class="support-status-bar">
		<span class={ "support-status", "status-" + rep.Status }>{ supportStatusLabel(rep.Status) }</span>
		if isAdmin {
			<span class="support-status-actions">
				for _, s := range supportStatuses() {
					if s != rep.Status {
						<button class="support-status-btn" data-on:click={ "@post('/report-issue/" + rep.IssueID + "/status?to=" + s + "')" }>
							{ supportStatusLabel(s) }
						</button>
					}
				}
			</span>
		}
	</div>
}

func supportStatuses() []string {
	return []string{"open", "triaged", "in_progress", "closed"}
}

func supportBackURL(isAdmin bool) templ.SafeURL {
	if isAdmin {
		return templ.SafeURL("/support-inbox")
	}
	return templ.SafeURL("/report-issue")
}

func supportBackLabel(isAdmin bool) string {
	if isAdmin {
		return "← Support inbox"
	}
	return "← All your reports"
}

func supportReportURL(iid string) templ.SafeURL {
	return templ.SafeURL("/report-issue/" + iid)
}

func supportRFC(u int64) string {
	return time.Unix(u, 0).UTC().Format(time.RFC3339)
}

func supportShort(u int64) string {
	return time.Unix(u, 0).UTC().Format("2006-01-02 15:04")
}

// supportStatusLabel maps the issue status to reporter-friendly wording.
func supportStatusLabel(s string) string {
	switch s {
	case "open":
		return "Open"
	case "triaged":
		return "Triaged"
	case "in_progress":
		return "In progress"
	case "closed":
		return "Resolved"
	}
	return s
}

func supportAuthor(c SupportCommentView) string {
	if c.IsMine {
		return "You"
	}
	if c.AuthorName == "" {
		return "Team"
	}
	return c.AuthorName
}
