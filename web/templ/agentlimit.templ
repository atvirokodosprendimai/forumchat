package templ

import (
	"strconv"
	"time"
)

// rateLimitSecs renders a retry-after duration as a whole number of seconds,
// rounded up, never below 1.
func rateLimitSecs(retry time.Duration) string {
	secs := int((retry + time.Second - 1) / time.Second)
	if secs < 1 {
		secs = 1
	}
	return strconv.Itoa(secs)
}

// NewUserHoldNotice renders a dismissible "you just joined — wait a bit" card
// into a stable slot, used to gate brand-new accounts (e.g. first chat post).
// action is the verb the user is blocked from ("post"); retry is how long until
// the account is old enough. Reuses the agent-notice slot + styling.
templ NewUserHoldNotice(slotID, action string, retry time.Duration) {
	<div id={ slotID } class="agent-notice-slot">
		<div class="agent-rate-notice" role="status" aria-live="polite" data-init="setTimeout(() => el.remove(), 8000)">
			<span class="agent-rate-notice-icon" aria-hidden="true">⏳</span>
			<span class="agent-rate-notice-text">
				Welcome! New members can { action } { rateLimitSecs(retry) }s from now.
			</span>
			<button type="button" class="agent-rate-notice-x" aria-label="Dismiss" data-on:click="el.closest('.agent-rate-notice').remove()">✕</button>
		</div>
	</div>
}

// ChatCmdNotice renders a dismissible info card into the agent-notice slot —
// used for slash-command feedback (e.g. an admin /bots toggle confirmation, or a
// "usage" / "admins only" hint). icon is a short emoji glyph; msg is plain text.
// Self-removes after a few seconds; the empty slot stays for later reuse.
templ ChatCmdNotice(slotID, icon, msg string) {
	<div id={ slotID } class="agent-notice-slot">
		<div class="agent-rate-notice" role="status" aria-live="polite" data-init="setTimeout(() => el.remove(), 6000)">
			<span class="agent-rate-notice-icon" aria-hidden="true">{ icon }</span>
			<span class="agent-rate-notice-text">{ msg }</span>
			<button type="button" class="agent-rate-notice-x" aria-label="Dismiss" data-on:click="el.closest('.agent-rate-notice').remove()">✕</button>
		</div>
	</div>
}

// AgentRateLimitNotice renders a dismissible "rate limit reached" card into a
// stable slot identified by slotID. The slot id must already exist on the page
// (empty); this outer-morphs the slot so it contains the card. The card
// self-removes after a few seconds — the empty slot stays in the DOM so a later
// throttle can re-fill it. retry is roughly how long until the member's
// per-minute budget frees up.
templ AgentRateLimitNotice(slotID string, retry time.Duration) {
	<div id={ slotID } class="agent-notice-slot">
		<div class="agent-rate-notice" role="status" aria-live="polite" data-init="setTimeout(() => el.remove(), 8000)">
			<span class="agent-rate-notice-icon" aria-hidden="true">⏳</span>
			<span class="agent-rate-notice-text">
				Rate limit reached — try again in { rateLimitSecs(retry) }s.
			</span>
			<button type="button" class="agent-rate-notice-x" aria-label="Dismiss" data-on:click="el.closest('.agent-rate-notice').remove()">✕</button>
		</div>
	</div>
}
