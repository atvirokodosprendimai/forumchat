package templ

import "encoding/json"

// OwnerSettingsData drives the owner-only tenant Settings page (SaaS). It
// carries the EFFECTIVE values (per-community override resolved against env) so
// unset fields show the platform default.
type OwnerSettingsData struct {
	Viewer           Viewer
	CommunitySlug    string
	CommunityName    string
	AIEnabled        bool
	JoinPolicy       string // open | request
	TranslateEnabled bool
	TranslateBaseURL string
	TranslateModel   string
	TranslatePlatform bool // served on platform AI → hide the operator's BYO infra
	RAGEnabled       bool
	RAGEmbedBaseURL  string
	RAGEmbedModel    string
	RAGEmbedDim      int
	RAGQdrantURL     string
	RAGHasQdrantKey  bool // a key is stored (don't echo it)
	RAGPlatform      bool // served on platform AI → hide the operator's BYO infra
	StorageBackend   string
	StorageOwnBucket bool
	StorageMigratable bool // SaaS + per-community storage available
	S3Endpoint       string
	S3Region         string
	S3Bucket         string
	HasS3Secret      bool
	Saved            bool

	// Platform AI (SaaS) — run RAG/translate/agents on the operator's hosted
	// compute instead of BYO. PlatformAIAvailable gates the whole card.
	PlatformAIAvailable   bool
	PlatformAIOn          bool   // owner master switch (requested/active)
	PlatformAIAuthorized  bool   // granted free OR active subscription
	PlatformAIStatus      string // requested | approved_unpaid | active | canceled | ""
	PlatformAIGrantedFree bool
	PlatformAISubscribed  bool
	BillingEnabled        bool // Stripe configured → show Subscribe
	PlatformUsage         []OwnerUsageRow
}

// OwnerUsageRow is one feature's rolling 30-day platform-compute usage, shown to
// the owner on the Platform AI card.
type OwnerUsageRow struct {
	Feature   string
	Requests  int
	TokensIn  int
	TokensOut int
}

func ownerSettingsSignals(d OwnerSettingsData) string {
	b, _ := json.Marshal(map[string]any{
		"set_ai_enabled":          d.AIEnabled,
		"set_join_policy":         d.JoinPolicy,
		"set_translate_enabled":   d.TranslateEnabled,
		"set_translate_base_url":  d.TranslateBaseURL,
		"set_translate_model":     d.TranslateModel,
		"set_rag_enabled":         d.RAGEnabled,
		"set_rag_embed_base_url":  d.RAGEmbedBaseURL,
		"set_rag_embed_model":     d.RAGEmbedModel,
		"set_rag_embed_dim":       d.RAGEmbedDim,
		"set_rag_qdrant_url":      d.RAGQdrantURL,
		"set_rag_qdrant_api_key":  "",
		"set_s3_endpoint":         d.S3Endpoint,
		"set_s3_region":           d.S3Region,
		"set_s3_bucket":           d.S3Bucket,
		"set_s3_access_key":       "",
		"set_s3_secret_key":       "",
	})
	return string(b)
}

templ OwnerSettingsPage(d OwnerSettingsData) {
	@Layout("Settings · "+d.CommunityName, d.Viewer) {
		<div class="container">
			if d.PlatformAIAvailable {
				@OwnerPlatformAICard(d)
			}
			@OwnerSettingsForm(d)
			@DataExportCard(d.CommunitySlug)
			@ownerDangerZone(d)
		</div>
	}
}

// OwnerPlatformAICard lets the owner opt into the platform's hosted AI compute
// (no servers to run) instead of configuring their own RAG/translate/agent
// endpoints below. It lives OUTSIDE the OwnerSettingsForm save-morph and carries
// its own stable id #owner-platform-ai so request/cancel morph it in place
// without disturbing the form. Authorization is the operator's call (free grant)
// or a subscription; until then the request sits "awaiting approval".
templ OwnerPlatformAICard(d OwnerSettingsData) {
	<section id="owner-platform-ai" class="card">
		<h2>⚡ Platform AI</h2>
		<p class="muted">
			Run RAG search, translation and agents on the platform's hosted AI —
			no Ollama/Qdrant servers to set up. When on, it replaces the BYO
			endpoints in the settings below. Access is granted by the platform
			operator, or via subscription.
		</p>
		<div id="owner-pai-error"></div>
		if !d.PlatformAIOn {
			<p class="muted">You're using your own AI configuration (BYO).</p>
			<button data-on:click={ "@post('/c/" + d.CommunitySlug + "/settings/platform-ai/request')" }>
				Use platform AI
			</button>
		} else if d.PlatformAIAuthorized {
			<p>
				<span class="role-pill active">● Active</span>
				if d.PlatformAIGrantedFree {
					<span class="muted">— sponsored by the platform</span>
				} else if d.PlatformAISubscribed {
					<span class="muted">— via your subscription</span>
				}
			</p>
			@ownerUsageTable(d.PlatformUsage)
			<button class="ghost danger" data-on:click={ "@post('/c/" + d.CommunitySlug + "/settings/platform-ai/cancel')" }>
				Stop using platform AI
			</button>
		} else {
			<p>
				<span class="role-pill">Requested</span>
				<span class="muted">— awaiting operator approval, or subscribe to start now.</span>
			</p>
			if d.BillingEnabled {
				<button data-on:click={ "@post('/c/" + d.CommunitySlug + "/settings/billing/checkout')" }>
					Subscribe &amp; activate
				</button>
			}
			<button class="ghost" data-on:click={ "@post('/c/" + d.CommunitySlug + "/settings/platform-ai/cancel')" }>
				Cancel request
			</button>
		}
	</section>
}

templ ownerUsageTable(rows []OwnerUsageRow) {
	if len(rows) == 0 {
		<p class="muted">No usage yet this period.</p>
	} else {
		<table class="data-table">
			<thead><tr><th>Feature</th><th>Requests</th><th>Tokens in</th><th>Tokens out</th></tr></thead>
			<tbody>
				for _, u := range rows {
					<tr>
						<td>{ u.Feature }</td>
						<td>{ itoa(u.Requests) }</td>
						<td>{ itoa(u.TokensIn) }</td>
						<td>{ itoa(u.TokensOut) }</td>
					</tr>
				}
			</tbody>
		</table>
		<p class="muted">Metered token usage over the last 30 days.</p>
	}
}

// ownerDangerZone is the irreversible community-delete card. It lives OUTSIDE
// the #owner-settings save-morph fragment so a settings save never resets the
// typed confirmation. The delete button stays disabled until the owner types
// the community slug back; the server re-checks the slug too (never trust the
// client). The slug is carried on a data-attr (not inlined into the JS
// expression) so a slug never has to be string-escaped.
templ ownerDangerZone(d OwnerSettingsData) {
	<section id="owner-danger" class="card narrow danger-zone" data-signals="{'set_delete_slug':''}">
		<h2>⚠️ Danger zone</h2>
		<p class="muted">
			Permanently delete <strong>{ d.CommunityName }</strong> and <strong>ALL</strong> of its
			data — every channel, message, thread, project, uploaded file and membership.
			This cannot be undone.
		</p>
		<label class="field">
			Type the slug <code>{ d.CommunitySlug }</code> to confirm
			<input type="text" data-bind="set_delete_slug" placeholder={ d.CommunitySlug } autocomplete="off" spellcheck="false"/>
		</label>
		<div id="owner-delete-error"></div>
		<button
			class="danger"
			data-slug={ d.CommunitySlug }
			data-attr:disabled="$set_delete_slug !== el.dataset.slug"
			data-on:click={ "@post('/c/" + d.CommunitySlug + "/settings/delete')" }
		>Delete this community forever</button>
	</section>
}

// OwnerSettingsForm is the stable-id fragment patched on save (§4.7 live-morph).
templ OwnerSettingsForm(d OwnerSettingsData) {
	<section id="owner-settings" class="card" data-signals={ ownerSettingsSignals(d) }>
		<h1>Tenant settings</h1>
		<p class="muted">Owner-only configuration for <strong>{ d.CommunityName }</strong>. RAG &amp; storage cards arrive with those backends.</p>
		<div class="card narrow">
			<h2>🤖 AI</h2>
			<label class="check"><input type="checkbox" data-bind="set_ai_enabled"/> Enable AI agents for this community</label>
			<p class="muted">Master switch. The platform must also have AI enabled for this to take effect.</p>
		</div>
		<div class="card narrow">
			<h2>🚪 Join policy</h2>
			<label class="check"><input type="radio" name="set_join_policy" value="open" data-bind="set_join_policy"/> Open — anyone may join instantly</label>
			<label class="check"><input type="radio" name="set_join_policy" value="request" data-bind="set_join_policy"/> Request — joins need owner/admin approval</label>
		</div>
		<div class="card narrow">
			<h2>🌐 Translation</h2>
			<label class="check"><input type="checkbox" data-bind="set_translate_enabled"/> Enable the /translate composer command</label>
			if d.TranslatePlatform {
				<p class="muted">Running on <strong>Platform AI</strong> — the translation endpoint and model are managed by the operator.</p>
			} else {
				<label class="field">Ollama host <input type="text" data-bind="set_translate_base_url" placeholder="http://localhost:11434"/></label>
				<label class="field">Model <input type="text" data-bind="set_translate_model" placeholder="e.g. llama3.2"/></label>
			}
		</div>
		<div class="card narrow">
			<h2>🔎 RAG (semantic search)</h2>
			<label class="check"><input type="checkbox" data-bind="set_rag_enabled"/> Enable semantic search over this community's public content</label>
			if d.RAGPlatform {
				<p class="muted">Running on <strong>Platform AI</strong> — the embedding model and vector store are managed by the operator.</p>
				<button class="secondary" data-on:click={ "@post('/c/" + d.CommunitySlug + "/admin/reindex')" }>Reindex this community</button>
			} else {
				<label class="field">Embedding Ollama host <input type="text" data-bind="set_rag_embed_base_url" placeholder="http://localhost:11434"/></label>
				<label class="field">Embedding model <input type="text" data-bind="set_rag_embed_model" placeholder="e.g. bge-m3"/></label>
				<label class="field">Vector size <input type="number" data-bind="set_rag_embed_dim" placeholder="1024"/></label>
				<label class="field">Qdrant URL <input type="text" data-bind="set_rag_qdrant_url" placeholder="http://localhost:6333"/></label>
				<label class="field">
					Qdrant API key
					if d.RAGHasQdrantKey {
						<input type="password" data-bind="set_rag_qdrant_api_key" placeholder="•••••• (stored — leave blank to keep)"/>
					} else {
						<input type="password" data-bind="set_rag_qdrant_api_key" placeholder="optional"/>
					}
				</label>
				<p class="muted">Changing the model or vector size requires a reindex (it rebuilds this community's collection at the new size).</p>
				<button class="secondary" data-on:click={ "@post('/c/" + d.CommunitySlug + "/admin/reindex')" }>Reindex this community</button>
			}
		</div>
		if d.StorageMigratable {
			<div class="card narrow">
				<h2>📦 Storage</h2>
				if d.StorageOwnBucket {
					<p class="muted">This community's files live in its own S3 bucket (<strong>{ d.S3Bucket }</strong>). Re-submit to update credentials or re-run the copy.</p>
				} else {
					<p class="muted">Files are on the shared platform store (<strong>{ d.StorageBackend }</strong>). Move them to your own S3 bucket for full data isolation — existing files are copied in the background; reads stay correct throughout.</p>
				}
				<label class="field">S3 endpoint <input type="text" data-bind="set_s3_endpoint" placeholder="(blank = AWS) https://s3.eu-central-1.amazonaws.com"/></label>
				<label class="field">Region <input type="text" data-bind="set_s3_region" placeholder="us-east-1"/></label>
				<label class="field">Bucket <input type="text" data-bind="set_s3_bucket" placeholder="my-community-bucket"/></label>
				<label class="field">Access key <input type="text" data-bind="set_s3_access_key" placeholder="AKIA…"/></label>
				<label class="field">
					Secret key
					if d.HasS3Secret {
						<input type="password" data-bind="set_s3_secret_key" placeholder="•••••• (stored — leave blank to keep)"/>
					} else {
						<input type="password" data-bind="set_s3_secret_key" placeholder="secret"/>
					}
				</label>
				<div id="owner-storage-error"></div>
				<button class="secondary" data-on:click={ "@post('/c/" + d.CommunitySlug + "/settings/migrate-storage')" }>Migrate to my S3</button>
			</div>
		}
		<div id="owner-settings-error"></div>
		<div class="row">
			<button data-on:click={ "@post('/c/" + d.CommunitySlug + "/settings')" }>Save settings</button>
			if d.Saved {
				<span class="muted">Saved ✓</span>
			}
		</div>
	</section>
}
