package templ

// landingBrand is the marketing/product name shown on the public index page.
// Placeholder while the SaaS brand is decided — change this one constant to
// rebrand the whole landing (nav, hero, footer, <title>, OG tags).
const landingBrand = "Commons"

// landingTagline is the one-line positioning used in the <title>, OG card and
// footer. Kept here so brand copy lives in one place.
const landingTagline = "One calm home for your community and team"

// ctaPrimaryLabel adapts the hero/nav primary button to the instance's signup
// mode: open self-serve registration vs invite-only. Mirrors the gate in
// internal/auth/handlers.go (OpenRegistration) so the copy never over-promises.
func ctaPrimaryLabel() string {
	if OpenRegistration {
		return "Start free"
	}
	return "Request access"
}

// ctaTrustNote is the small reassurance line under the primary CTA.
func ctaTrustNote() string {
	if OpenRegistration {
		return "Free to start · No credit card required"
	}
	return "Invite-only · Bring a code from an admin"
}

// LandingPage is the public, unauthenticated index at "/". A self-contained
// marketing document (its own slim, SEO-friendly head — no app sidebar, no
// Datastar) that sells the product and routes visitors to /register and
// /login. Feature copy is flag-aware so it stays honest to what this instance
// actually runs.
templ LandingPage() {
	<!DOCTYPE html>
	<html lang="en" class="lp-doc">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width,initial-scale=1"/>
			<title>{ landingBrand } — { landingTagline }</title>
			<meta name="description" content="Real-time chat, threaded forums, video rooms and AI agents in one fast, self-hosted space. The all-in-one platform for communities and teams."/>
			<meta name="robots" content="index,follow"/>
			<meta property="og:type" content="website"/>
			<meta property="og:title" content={ landingBrand + " — " + landingTagline }/>
			<meta property="og:description" content="Chat, forum, rooms and AI agents — together in a single calm space for your community and team."/>
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=JetBrains+Mono:wght@400;600&display=swap"/>
			@InlineStyle("app.css")
			<link rel="icon" type="image/svg+xml" href="/static/icon.svg"/>
			<link rel="apple-touch-icon" href="/static/icon-192.png"/>
			<meta name="theme-color" content={ themeColor("") }/>
		</head>
		<body class="lp">
			@landingNav()
			<main class="lp-main">
				@landingHero()
				@landingFeatures()
				@landingHow()
				@landingUseCases()
				@landingFinalCTA()
			</main>
			@landingFooter()
		</body>
	</html>
}

// landingNav — sticky marketing header: brand left, anchor links + auth CTAs
// right. Auth actions are top-level navigations (not Datastar), so they're
// plain <a href>, same rationale as the OAuth buttons (§5e).
templ landingNav() {
	<header class="lp-nav">
		<a href="/" class="lp-logo">
			<span class="lp-logo-mark" aria-hidden="true">◇</span>
			<span class="lp-logo-word">{ landingBrand }</span>
		</a>
		<nav class="lp-nav-links" aria-label="Sections">
			<a href="#features">Features</a>
			<a href="#how">How it works</a>
			<a href="#use-cases">Use cases</a>
		</nav>
		<div class="lp-nav-cta">
			<a href="/login" class="btn ghost">Sign in</a>
			<a href="/register" class="btn">{ ctaPrimaryLabel() }</a>
		</div>
	</header>
}

// landingHero — the above-the-fold pitch: eyebrow, headline, subhead, dual CTA,
// trust note, and a pure-CSS product preview (no image asset to load).
templ landingHero() {
	<section class="lp-hero" aria-label="Introduction">
		<div class="lp-hero-copy">
			<span class="lp-eyebrow">✦ All-in-one community platform</span>
			<h1 class="lp-h1">
				Where your community<br/>
				<span class="lp-h1-accent">actually lives.</span>
			</h1>
			<p class="lp-sub">
				Real-time chat, threaded discussions, video rooms and AI agents —
				together in a single fast space. Self-hosted, no sprawl, no
				per-seat surprises.
			</p>
			<div class="lp-hero-actions">
				<a href="/register" class="btn lp-btn-lg">{ ctaPrimaryLabel() }</a>
				<a href="/login" class="btn ghost lp-btn-lg">Sign in</a>
			</div>
			<p class="lp-trust">{ ctaTrustNote() }</p>
		</div>
		<div class="lp-hero-art" aria-hidden="true">
			@landingPreview()
		</div>
	</section>
}

// landingPreview — a decorative, pure-HTML/CSS mock of the product: a window
// chrome wrapping a mini channel list, a few chat bubbles and a forum thread.
// Marked aria-hidden — purely illustrative.
templ landingPreview() {
	<div class="lp-window">
		<div class="lp-window-bar">
			<span class="lp-dot"></span><span class="lp-dot"></span><span class="lp-dot"></span>
			<span class="lp-window-title">{ landingBrand } · #general</span>
		</div>
		<div class="lp-window-body">
			<aside class="lp-mini-rail">
				<span class="lp-mini-chan lp-mini-active"># general</span>
				<span class="lp-mini-chan"># product</span>
				<span class="lp-mini-chan"># random</span>
				<span class="lp-mini-sep"></span>
				<span class="lp-mini-chan lp-mini-thread">📋 Threads</span>
				<span class="lp-mini-chan lp-mini-thread">🎥 Rooms</span>
			</aside>
			<div class="lp-mini-stream">
				<div class="lp-bubble">
					<span class="lp-ava lp-ava-a">A</span>
					<div class="lp-bubble-body"><strong>Ada</strong><span>Shipping the new onboarding today 🚀</span></div>
				</div>
				<div class="lp-bubble">
					<span class="lp-ava lp-ava-b">M</span>
					<div class="lp-bubble-body"><strong>Mira</strong><span>Promoted it to a thread so we can track feedback.</span></div>
				</div>
				<div class="lp-bubble lp-bubble-bot">
					<span class="lp-ava lp-ava-bot">✦</span>
					<div class="lp-bubble-body"><strong>Assistant</strong><span>Summary + 3 action items posted to the thread.</span></div>
				</div>
				<div class="lp-mini-thread-card">
					<span class="lp-thread-pill">📋 Thread</span>
					<strong>New onboarding — feedback</strong>
					<span class="lp-thread-meta">4 replies · 2 participants</span>
				</div>
			</div>
		</div>
	</div>
}

// landingFeatures — flag-aware capability grid. Core features always render;
// AI / Projects / Rooms-guest / Time follow the instance flags (layout.templ),
// so the page never advertises a feature that's switched off here.
templ landingFeatures() {
	<section id="features" class="lp-section" aria-label="Features">
		<div class="lp-section-head">
			<span class="lp-kicker">Everything in one place</span>
			<h2 class="lp-h2">Stop stitching five tools together</h2>
			<p class="lp-lead">Chat, forum, rooms and AI live in the same fast app — one login, one search, one source of truth.</p>
		</div>
		<div class="lp-grid">
			@landingFeature("💬", "Realtime chat channels", "Public named channels with @mentions, replies, image paste and instant fan-out over NATS.")
			@landingFeature("📋", "Forum threads", "Long-form discussions that don't scroll away. Promote any chat message into a thread in one click.")
			@landingFeature("🎥", "Video rooms", "Spin up a WebRTC room and jump on a call without leaving your community.")
			if AIEnabled {
				@landingFeature("🤖", "AI agents", "@mention an agent — it opens a thread and answers with tools and your knowledge base.")
			}
			if ProjectsEnabled {
				@landingFeature("📂", "Projects & issues", "Track work with issues, checklists and attachments right next to the conversation.")
			}
			@landingFeature("🔍", "Full-text search", "Find any message or thread instantly with built-in SQLite FTS.")
			@landingFeature("🛡", "Roles & moderation", "Per-community admins, approval queues and bans with content cleanup — built in.")
			if TimeEnabled {
				@landingFeature("⏱", "Time & budget", "Log time against work and watch budgets without a second tool.")
			}
			@landingFeature("⚡", "Self-hosted & fast", "A single Go binary on SQLite + NATS. Deploy in minutes, own your data.")
		</div>
	</section>
}

// landingFeature — one capability card. Small reusable unit (DRY) so the grid
// above is just data.
templ landingFeature(icon, title, body string) {
	<article class="lp-card">
		<span class="lp-card-icon" aria-hidden="true">{ icon }</span>
		<h3 class="lp-card-title">{ title }</h3>
		<p class="lp-card-body">{ body }</p>
	</article>
}

// landingHow — three-step "how it works". Step 2 copy is flag-aware.
templ landingHow() {
	<section id="how" class="lp-section lp-section-alt" aria-label="How it works">
		<div class="lp-section-head">
			<span class="lp-kicker">Up and running fast</span>
			<h2 class="lp-h2">From zero to a living space in minutes</h2>
		</div>
		<ol class="lp-steps">
			<li class="lp-step">
				<span class="lp-step-num">1</span>
				<h3>Create your space</h3>
				<p>Spin up a community or team workspace — a chat channel and forum are ready instantly.</p>
			</li>
			<li class="lp-step">
				<span class="lp-step-num">2</span>
				<h3>Invite your people</h3>
				if OpenRegistration {
					<p>Open self-serve signup or share invite codes — you decide how members get in.</p>
				} else {
					<p>Send invite codes and approve who joins. You stay in control of the door.</p>
				}
			</li>
			<li class="lp-step">
				<span class="lp-step-num">3</span>
				<h3>Talk, decide, ship</h3>
				<p>Chat in real time, capture decisions in threads, and meet in rooms — all searchable.</p>
			</li>
		</ol>
	</section>
}

// landingUseCases — who it's for. Balanced across communities and teams.
templ landingUseCases() {
	<section id="use-cases" class="lp-section" aria-label="Use cases">
		<div class="lp-section-head">
			<span class="lp-kicker">Built for</span>
			<h2 class="lp-h2">One platform, every kind of group</h2>
		</div>
		<div class="lp-usecases">
			<article class="lp-usecase">
				<span class="lp-usecase-icon" aria-hidden="true">🌐</span>
				<h3>Communities & creators</h3>
				<p>Give members a real home — channels to hang out, threads that stay, and rooms to gather.</p>
			</article>
			<article class="lp-usecase">
				<span class="lp-usecase-icon" aria-hidden="true">🏢</span>
				<h3>Teams & businesses</h3>
				<p>An internal hub where chat, decisions and project tracking finally sit in one place.</p>
			</article>
			<article class="lp-usecase">
				<span class="lp-usecase-icon" aria-hidden="true">🛟</span>
				<h3>Support & operations</h3>
				<p>Approval queues, roles and an audit trail baked in — no plugins, no spreadsheets.</p>
			</article>
		</div>
	</section>
}

// landingFinalCTA — closing conversion band.
templ landingFinalCTA() {
	<section class="lp-cta-band" aria-label="Get started">
		<h2 class="lp-cta-title">Ready when you are.</h2>
		<p class="lp-cta-sub">Bring your community and team into one calm, fast space.</p>
		<div class="lp-hero-actions lp-cta-actions">
			<a href="/register" class="btn lp-btn-lg">{ ctaPrimaryLabel() }</a>
			<a href="/login" class="btn ghost lp-btn-lg">Sign in</a>
		</div>
	</section>
}

// landingFooter — marketing footer with brand, auth links and build version.
templ landingFooter() {
	<footer class="lp-footer">
		<div class="lp-footer-brand">
			<a href="/" class="lp-logo">
				<span class="lp-logo-mark" aria-hidden="true">◇</span>
				<span class="lp-logo-word">{ landingBrand }</span>
			</a>
			<p class="lp-footer-tag">{ landingTagline }.</p>
		</div>
		<nav class="lp-footer-links" aria-label="Footer">
			<a href="/login">Sign in</a>
			<a href="/register">{ ctaPrimaryLabel() }</a>
		</nav>
		<div class="lp-footer-meta">
			<span>Built by <a href="https://ituoga.lt" target="_blank" rel="noopener">ituoga.lt</a> and Claude</span>
			<span class="fc-version" title="Build version">{ Version }</span>
		</div>
	</footer>
}
