package templ

import "encoding/json"

// SaaSEnabled mirrors config.SAAS (set at boot in main.go). When true the
// public "/" renders the marketing LandingPage; when false anonymous visitors
// are routed straight to /login. Read by the dashboard handler.
var SaaSEnabled bool

// SaaSBrand mirrors config.SAASBrand — the product name shown across the
// landing. Empty falls back to a neutral placeholder via brandName().
var SaaSBrand string

// brandName is the marketing/product name used everywhere on the landing
// (nav, hero, footer, <title>, OG tags). Driven by SAAS_BRAND with a
// placeholder fallback so the page never renders an empty brand.
func brandName() string {
	if SaaSBrand != "" {
		return SaaSBrand
	}
	return "Commons"
}

// landingTagline is the one-line positioning used in the <title>, OG card and
// footer. Kept here so brand copy lives in one place. Community-first: this is
// built for small communities, not enterprises.
const landingTagline = "A calm home for your community"

// landingRepoURL is the public source repository, linked from the landing nav
// and footer — this is open source.
const landingRepoURL = "https://github.com/atvirokodosprendimai/forumchat"

// ctaPrimaryLabel adapts the hero/nav primary button to the instance's signup
// mode: open self-serve registration vs invite-only. Mirrors the gate in
// internal/auth/handlers.go (OpenRegistration) so the copy never over-promises.
func ctaPrimaryLabel() string {
	if OpenRegistration {
		return "Start free"
	}
	return "Request access"
}

// ctaTrustNote is the small reassurance line under the primary CTA.
func ctaTrustNote() string {
	if OpenRegistration {
		return "Free to start · No credit card required"
	}
	return "Invite-only · Bring a code from an admin"
}

// landingKeywords feeds the <meta name="keywords"> tag. Not a ranking signal on
// its own anymore, but harmless and a tidy summary of what the page is about —
// kept aligned with the alternative-to copy in landingReplaces.
const landingKeywords = "self-hosted community platform, Discord alternative, " +
	"open source forum software, Discourse alternative, self-hosted chat, " +
	"realtime chat and forum, video rooms, WebRTC, self-hosted AI assistant, " +
	"Ollama, single binary, SQLite, own your data, AGPL, community software"

// lpFAQ is one question/answer pair. It is the single source for BOTH the
// human-readable accordion (landingFAQ) AND the FAQPage structured data
// (structuredData) — write a question once, it renders and gets marked up.
type lpFAQ struct {
	Q, A string
}

// landingFAQItems returns the FAQ shown on the landing and emitted as
// schema.org FAQPage JSON-LD. Answers are plain prose (no markup) so they are
// valid both as visible text and as structured-data strings. Flag-aware: the
// AI answer only appears when the assistant is actually enabled, so the page
// never answers a question about a feature this instance doesn't run.
func landingFAQItems() []lpFAQ {
	brand := brandName()
	items := []lpFAQ{
		{
			"What is " + brand + "?",
			brand + " is a self-hosted community platform that combines realtime chat, " +
				"a threaded forum, video rooms and search in one fast app. Think of it as " +
				"Discord and a discussion forum living in the same place, running on a server " +
				"you control instead of someone else's cloud.",
		},
		{
			"Is it really free?",
			"Yes. " + brand + " is open-source software (AGPL-3.0) you can run yourself at no " +
				"licence cost. There is no per-seat pricing and no paid tier to unlock core " +
				"features — your only cost is the small server it runs on, which can be a $5 VPS.",
		},
		{
			"Do I need to be a developer to use it?",
			"To take part in a community, no — you sign in and start chatting like any other app. " +
				"To host your own, you run a single container; if you can copy and paste one command " +
				"you can stand it up. There is no build pipeline, database server or cluster to manage.",
		},
		{
			"Where is my data stored?",
			"Everything lives in one SQLite database file plus an uploads folder on your own server. " +
				"Nothing is sent to a third party, there is no telemetry, and backing up your whole " +
				"community is as simple as copying that file. If you ever want to leave, you take " +
				"everything with you.",
		},
		{
			"How is this different from Discord or Slack?",
			"Chat apps are great for the moment but terrible for memory — good ideas scroll away and " +
				"you don't own the history. " + brand + " pairs the same realtime chat with a durable " +
				"forum so decisions stay findable for years, and you host it yourself, so there are no " +
				"ads, no algorithmic feed and no company that can lock you out or archive your space.",
		},
		{
			"Does it work on phones?",
			"Yes. The interface is server-rendered HTML that adapts to small screens, so it works in " +
				"any mobile browser with no app to install. You can also opt in to web push notifications " +
				"for mentions and new threads — with a digest mode so your phone doesn't buzz on every message.",
		},
		{
			"Can I invite people who don't have an account?",
			"Communities can be public and discoverable or invite-only, and admins control who gets in. " +
				"Guest lobbies can also be enabled, letting you share a single link with an outsider for a " +
				"quick conversation without forcing them to register first.",
		},
	}
	if AIEnabled {
		items = append(items, lpFAQ{
			"Does the AI assistant send my conversations to OpenAI?",
			"No. The built-in assistant points at your own AI server (such as Ollama) running models " +
				"you choose. Prompts and answers never leave your infrastructure, and there is no third-party " +
				"API key to buy — the AI is just another part of the box you already control.",
		})
	}
	return items
}

// structuredData returns ready-to-embed JSON-LD (schema.org) describing the
// product as a SoftwareApplication and the FAQ as a FAQPage. Marshalled via
// encoding/json so it is always valid JSON and HTML-safe (json escapes < > &),
// then emitted with templ.Raw. Inputs are operator-controlled brand/copy, not
// user input, so this is injection-safe. Better AI/Google answer-engine
// surfacing without changing what humans see.
func structuredData() string {
	app := map[string]any{
		"@context":            "https://schema.org",
		"@type":               "SoftwareApplication",
		"name":                brandName(),
		"applicationCategory": "CommunicationApplication",
		"operatingSystem":     "Linux, Docker (self-hosted)",
		"description": "Self-hosted community platform combining realtime chat, a threaded " +
			"forum, video rooms, search and an optional AI assistant in a single binary. " +
			"Own your data — no per-seat fees, no ads, no lock-in.",
		"url":          landingRepoURL,
		"softwareHelp": landingRepoURL,
		"offers": map[string]any{
			"@type":         "Offer",
			"price":         "0",
			"priceCurrency": "USD",
		},
	}
	faqs := landingFAQItems()
	entities := make([]map[string]any, 0, len(faqs))
	for _, f := range faqs {
		entities = append(entities, map[string]any{
			"@type": "Question",
			"name":  f.Q,
			"acceptedAnswer": map[string]any{
				"@type": "Answer",
				"text":  f.A,
			},
		})
	}
	faqPage := map[string]any{
		"@context":   "https://schema.org",
		"@type":      "FAQPage",
		"mainEntity": entities,
	}
	appJSON, _ := json.Marshal(app)
	faqJSON, _ := json.Marshal(faqPage)
	return `<script type="application/ld+json">` + string(appJSON) + `</script>` +
		`<script type="application/ld+json">` + string(faqJSON) + `</script>`
}

// LandingPage is the public, unauthenticated index at "/". A self-contained
// marketing document (its own slim, SEO-friendly head — no app sidebar, no
// Datastar) that sells the product and routes visitors to /register and
// /login. Feature copy is flag-aware so it stays honest to what this instance
// actually runs.
templ LandingPage() {
	<!DOCTYPE html>
	<html lang="en" class="lp-doc">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width,initial-scale=1"/>
			<title>{ brandName() } — { landingTagline }</title>
			<meta name="description" content="Real-time chat, threaded forums, video rooms and an optional AI assistant in one fast, self-hosted space. An open-source Discord + forum alternative for small communities who want to own their home online, not rent it."/>
			<meta name="keywords" content={ landingKeywords }/>
			<meta name="robots" content="index,follow"/>
			<meta name="author" content={ brandName() }/>
			<meta property="og:type" content="website"/>
			<meta property="og:site_name" content={ brandName() }/>
			<meta property="og:title" content={ brandName() + " — " + landingTagline }/>
			<meta property="og:description" content="Chat, forum, video rooms and AI in one calm, self-hosted space you actually own. An open-source alternative to scattering your community across Discord, a forum and a video tool."/>
			<meta name="twitter:card" content="summary_large_image"/>
			<meta name="twitter:title" content={ brandName() + " — " + landingTagline }/>
			<meta name="twitter:description" content="Realtime chat + forum + video rooms + AI, self-hosted in a single binary. Own your community's data."/>
			@templ.Raw(structuredData())
			<link rel="preconnect" href="https://fonts.googleapis.com"/>
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
			<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400..700&family=JetBrains+Mono:wght@400;600&display=swap"/>
			@InlineStyle("app.css")
			<link rel="icon" type="image/svg+xml" href="/static/icon.svg"/>
			<link rel="apple-touch-icon" href="/static/icon-192.png"/>
			<meta name="theme-color" content={ themeColor("") }/>
		</head>
		<body class="lp">
			@landingNav()
			<main class="lp-main">
				@landingHero()
				@landingReplaces()
				@landingFeatures()
				@landingDeepDive()
				@landingHow()
				@landingPrivacy()
				@landingUseCases()
				@landingTech()
				@landingConnectors()
				@landingFAQ()
				@landingFinalCTA()
			</main>
			@landingFooter()
		</body>
	</html>
}

// landingNav — sticky marketing header: brand left, anchor links + auth CTAs
// right. Auth actions are top-level navigations (not Datastar), so they're
// plain <a href>, same rationale as the OAuth buttons (§5e).
templ landingNav() {
	<header class="lp-nav">
		<a href="/" class="lp-logo">
			<span class="lp-logo-mark" aria-hidden="true">◇</span>
			<span class="lp-logo-word">{ brandName() }</span>
		</a>
		<nav class="lp-nav-links" aria-label="Sections">
			<a href="#features">Features</a>
			<a href="#how">How it works</a>
			<a href="#use-cases">Use cases</a>
			<a href="#developers">Developers</a>
			<a href={ templ.URL(landingRepoURL) } target="_blank" rel="noopener">GitHub</a>
		</nav>
		<div class="lp-nav-cta">
			<a href="/login" class="btn ghost">Sign in</a>
			<a href="/register" class="btn">{ ctaPrimaryLabel() }</a>
		</div>
	</header>
}

// landingHero — the above-the-fold pitch: eyebrow, headline, subhead, dual CTA,
// trust note, and a pure-CSS product preview (no image asset to load).
templ landingHero() {
	<section class="lp-hero" aria-label="Introduction">
		<div class="lp-hero-copy">
			<span class="lp-eyebrow">✦ Built for small communities</span>
			<h1 class="lp-h1">
				Where your community<br/>
				<span class="lp-h1-accent">actually lives.</span>
			</h1>
			<p class="lp-sub">
				Real-time chat, threaded discussions and video rooms—
				one calm little home for your community. Self-hosted on a
				single box, no per-seat fees, no ads, no algorithms.
			</p>
			<div class="lp-hero-actions">
				<a href="/register" class="btn lp-btn-lg">{ ctaPrimaryLabel() }</a>
				<a href="/login" class="btn ghost lp-btn-lg">Sign in</a>
			</div>
			<p class="lp-trust">{ ctaTrustNote() }</p>
		</div>
		<div class="lp-hero-art" aria-hidden="true">
			@landingPreview()
		</div>
	</section>
}

// landingPreview — a decorative, pure-HTML/CSS mock of the product: a window
// chrome wrapping a mini channel list, a few chat bubbles and a forum thread.
// Marked aria-hidden — purely illustrative.
templ landingPreview() {
	<div class="lp-window">
		<div class="lp-window-bar">
			<span class="lp-dot"></span><span class="lp-dot"></span><span class="lp-dot"></span>
			<span class="lp-window-title">{ brandName() } · #general</span>
		</div>
		<div class="lp-window-body">
			<aside class="lp-mini-rail">
				<span class="lp-mini-chan lp-mini-active"># general</span>
				<span class="lp-mini-chan"># product</span>
				<span class="lp-mini-chan"># random</span>
				<span class="lp-mini-sep"></span>
				<span class="lp-mini-chan lp-mini-thread">📋 Threads</span>
				<span class="lp-mini-chan lp-mini-thread">🎥 Rooms</span>
			</aside>
			<div class="lp-mini-stream">
				<div class="lp-bubble">
					<span class="lp-ava lp-ava-a">A</span>
					<div class="lp-bubble-body"><strong>Ada</strong><span>Anyone up for the Saturday hike? 🥾</span></div>
				</div>
				<div class="lp-bubble">
					<span class="lp-ava lp-ava-b">M</span>
					<div class="lp-bubble-body"><strong>Mira</strong><span>Promoted it to a thread so we can plan the route.</span></div>
				</div>
				<div class="lp-bubble lp-bubble-bot">
					<span class="lp-ava lp-ava-bot">✦</span>
					<div class="lp-bubble-body"><strong>Assistant</strong><span>Trail map + Saturday weather posted to the thread.</span></div>
				</div>
				<div class="lp-mini-thread-card">
					<span class="lp-thread-pill">📋 Thread</span>
					<strong>Saturday hike — who's in?</strong>
					<span class="lp-thread-meta">4 replies · 2 going</span>
				</div>
			</div>
		</div>
	</div>
}

// landingFeatures — flag-aware capability grid. Core features always render;
// AI / Projects / Rooms-guest / Time follow the instance flags (layout.templ),
// so the page never advertises a feature that's switched off here.
templ landingFeatures() {
	<section id="features" class="lp-section" aria-label="Features">
		<div class="lp-section-head">
			<span class="lp-kicker">Everything in one place</span>
			<h2 class="lp-h2">Stop scattering your community across apps</h2>
			<p class="lp-lead">Chat, forum, rooms and AI live in the same fast app — one login, one search, one home your members actually own.</p>
		</div>
		<div class="lp-grid">
			@landingFeature("💬", "Realtime chat channels", "Public named channels with @mentions, replies, image paste and instant fan-out over NATS.")
			@landingFeature("📋", "Forum threads", "Long-form discussions that don't scroll away. Promote any chat message into a thread in one click.")
			@landingFeature("🎥", "Video rooms", "Spin up a WebRTC room and jump on a call without leaving your community.")
			if AIEnabled {
				@landingFeature("🤖", "AI agents", "@mention an agent — it opens a thread and answers with tools and your knowledge base.")
			}
			if ProjectsEnabled {
				@landingFeature("📂", "Projects & issues", "Track work with issues, checklists and attachments right next to the conversation.")
			}
			@landingFeature("🔍", "Full-text search", "Find any message or thread instantly with built-in SQLite FTS.")
			@landingFeature("🛡", "Roles & moderation", "Admins, approval queues and bans with content cleanup — keep your space friendly without hiring a mod team.")
			if TimeEnabled {
				@landingFeature("⏱", "Time & budget", "Log time against work and watch budgets without a second tool.")
			}
			@landingFeature("⚡", "Self-hosted & cheap", "A single Go binary on SQLite — runs on the smallest box. Deploy in minutes, own every message.")
		</div>
	</section>
}

// landingFeature — one capability card. Small reusable unit (DRY) so the grid
// above is just data.
templ landingFeature(icon, title, body string) {
	<article class="lp-card">
		<span class="lp-card-icon" aria-hidden="true">{ icon }</span>
		<h3 class="lp-card-title">{ title }</h3>
		<p class="lp-card-body">{ body }</p>
	</article>
}

// landingHow — three-step "how it works". Step 2 copy is flag-aware.
templ landingHow() {
	<section id="how" class="lp-section lp-section-alt" aria-label="How it works">
		<div class="lp-section-head">
			<span class="lp-kicker">Up and running fast</span>
			<h2 class="lp-h2">From zero to a living community in minutes</h2>
		</div>
		<ol class="lp-steps">
			<li class="lp-step">
				<span class="lp-step-num">1</span>
				<h3>Create your space</h3>
				<p>Spin up your community — a chat channel and forum are ready the moment you sign up.</p>
			</li>
			<li class="lp-step">
				<span class="lp-step-num">2</span>
				<h3>Invite your people</h3>
				if OpenRegistration {
					<p>Open self-serve signup or share invite codes — you decide how members get in.</p>
				} else {
					<p>Send invite codes and approve who joins. You stay in control of the door.</p>
				}
			</li>
			<li class="lp-step">
				<span class="lp-step-num">3</span>
				<h3>Talk, decide, ship</h3>
				<p>Chat in real time, capture decisions in threads, and meet in rooms — all searchable.</p>
			</li>
		</ol>
	</section>
}

// landingUseCases — who it's for. Community-first: small communities lead,
// small teams kept as a single secondary card.
templ landingUseCases() {
	<section id="use-cases" class="lp-section" aria-label="Use cases">
		<div class="lp-section-head">
			<span class="lp-kicker">Built for</span>
			<h2 class="lp-h2">Made for small communities</h2>
		</div>
		<div class="lp-usecases">
			<article class="lp-usecase">
				<span class="lp-usecase-icon" aria-hidden="true">🎲</span>
				<h3>Clubs, hobbies & fandoms</h3>
				<p>Give your members a real home: channels to hang out, threads that stay put, and rooms to meet up.</p>
			</article>
			<article class="lp-usecase">
				<span class="lp-usecase-icon" aria-hidden="true">🏡</span>
				<h3>Friends & local groups</h3>
				<p>A private corner of the internet for your circle, neighborhood or meetup. No ads, no algorithm, just your people.</p>
			</article>
			<article class="lp-usecase">
				<span class="lp-usecase-icon" aria-hidden="true">🛠️</span>
				<h3>Small teams & makers</h3>
				<p>Tiny teams and side-projects get chat, decisions and tracking in one place, without enterprise pricing.</p>
			</article>
		</div>
	</section>
}

// landingReplaces — "one app instead of five tabs". Each card names a familiar
// tool people already search for (Discord, a forum, Zoom, a wiki, ChatGPT) so
// the page answers the "alternative to X" queries that bring small-community
// hosts here, and shows the consolidation story in one glance. Flag-aware: the
// AI card only appears when the assistant is enabled.
templ landingReplaces() {
	<section class="lp-section" aria-label="What it replaces">
		<div class="lp-section-head">
			<span class="lp-kicker">One home, not ten tabs</span>
			<h2 class="lp-h2">Replace the pile of apps your community is scattered across</h2>
			<p class="lp-lead">Most small communities end up juggling a chat app, a forum, a video tool, a docs site and a notifications service — each with its own login, its own bill, and its own silo of history. { brandName() } folds them into one calm place you host yourself.</p>
		</div>
		<div class="lp-grid">
			@landingReplace("💬", "Instead of Discord", "A realtime chat server", "Named channels, @mentions, replies, image paste and live fan-out — without the ads, the algorithm, or losing your history behind a paywall.")
			@landingReplace("📋", "Instead of a forum", "Discourse-style threads", "Long-form discussions that stay put and stay searchable. Promote any chat message into a thread the moment it deserves a real conversation.")
			@landingReplace("🎥", "Instead of Zoom or Jitsi", "Built-in video rooms", "Jump on a WebRTC call with screen share right inside your community. Nothing to install, no meeting links to schedule, no third-party room limits.")
			@landingReplace("🗂", "Instead of a SaaS wiki", "Projects, notes & pastes", "Capture decisions, track issues and share long snippets next to the conversation that produced them — not in yet another tool nobody opens.")
			if AIEnabled {
				@landingReplace("🤖", "Instead of paying for ChatGPT", "Your own AI assistant", "An in-house assistant that answers in a thread, searches your community and runs on models you host — so prompts never leave your box and there's no usage bill.")
			}
			@landingReplace("☁️", "Instead of a monthly SaaS bill", "A box you actually own", "One small server, one database file. No per-seat pricing, no seat counting, no \"your free workspace will be archived\" email two years from now.")
		</div>
	</section>
}

// landingReplace — one "instead of X" card. Reusable unit so landingReplaces is
// just data (DRY, mirrors landingFeature).
templ landingReplace(icon, eyebrow, title, body string) {
	<article class="lp-card lp-replace">
		<span class="lp-card-icon" aria-hidden="true">{ icon }</span>
		<span class="lp-replace-eyebrow">{ eyebrow }</span>
		<h3 class="lp-card-title">{ title }</h3>
		<p class="lp-card-body">{ body }</p>
	</article>
}

// landingDeepDive — the long-form, human-readable heart of the page: a few
// alternating prose rows that actually explain how each pillar feels to use,
// rather than just listing it. This is where a curious reader (and a search
// engine reading for substance) gets the real story. AI row is flag-gated.
templ landingDeepDive() {
	<section id="deep-dive" class="lp-section lp-section-alt" aria-label="How it feels to use">
		<div class="lp-section-head">
			<span class="lp-kicker">A closer look</span>
			<h2 class="lp-h2">Everything your community needs, and nothing it doesn't</h2>
			<p class="lp-lead">No feature soup and no enterprise dashboard — just the handful of things a living community actually uses every day, done carefully.</p>
		</div>
		<div class="lp-deep">
			@landingDeepRow("Chat that feels instant", []string{
				"Conversation is where a community comes alive, so chat is the centre of gravity here. Messages appear the instant they're sent — no refresh, no spinner — because every update streams straight to the page over a live connection. Type, paste an image, drop a file, reply with a quote, or forward something to another channel; it all lands immediately for everyone watching.",
				"Channels keep different conversations from stepping on each other, unread dots quietly tell you where something new happened, and when a casual message turns into something worth keeping, one click promotes it into a forum thread so it doesn't scroll away forever.",
			}, []string{"Named channels", "@mentions", "Image paste & drop", "Reply quotes", "Forward to channel", "Unread dots"})
			@landingDeepRow("A forum so good ideas don't scroll away", []string{
				"Chat is brilliant for the moment and terrible for memory. The built-in forum is the antidote: durable threads with flat, readable replies that stay findable months and years later. Decisions, plans, guides and announcements live here instead of evaporating in the scrollback.",
				"Threads can be marked resolved, filtered, quoted and searched, and a new thread can announce itself back into chat so nobody misses it. It's the difference between a community that remembers and one that keeps re-asking the same questions.",
			}, []string{"Durable threads", "Resolved / unresolved", "Single-parent quotes", "Chat → thread bridge", "Self-delete grace window"})
			@landingDeepRow("Search that actually finds things", []string{
				"Everything you write is searchable the moment it's posted. A built-in full-text index returns exact matches instantly across chat, threads, posts, projects and more — no external search service to run.",
				"When semantic search is switched on, results also include things that mean the same without using the same words, and the two are blended into one ranked list. Every hit links straight back to where it lives, so finding the answer is one query and one click away.",
			}, []string{"Instant full-text", "Optional semantic search", "One blended result list", "Deep links to source", "Search from the chat box"})
			if AIEnabled {
				@landingDeepRow("An assistant that lives in your community", []string{
					"The optional AI assistant isn't a bolt-on chatbot — it's a member of the space. @mention it and it opens a thread, answers with context from your own discussions, and can use tools to search or pull in what it needs. Multiple named assistants can each have their own personality and purpose.",
					"Crucially, it runs on AI models you host. Your prompts and your community's knowledge never leave your server, and there's no metered API bill — the assistant is simply another part of the box you already own.",
				}, []string{"Answers in a thread", "Knows your content", "Multiple named agents", "Tool & search access", "Runs on your own models"})
			}
			@landingDeepRow("Meet face to face, nothing to install", []string{
				"Sometimes you just need to talk. Always-on video rooms let anyone hop on a call with camera, mic and screen share directly in the browser — no app download, no scheduling, no separate meeting tool.",
				"Screen and camera show up as independent tiles so a presenter stays visible while sharing, and background blur keeps your messy room your business. It's the quick huddle your community needs, without leaving the community.",
			}, []string{"WebRTC in-browser", "Screen + camera tiles", "Background blur", "Always-on rooms", "Stage & fullscreen"})
			@landingDeepRow("Notifications that respect your attention", []string{
				"Being reachable shouldn't mean being interrupted. Web push notifications let members keep up with mentions, new threads and other events from their phone or desktop — entirely opt-in, with per-event control over what's worth a buzz.",
				"A digest mode batches everything into a single quiet update every few minutes or hours, so an active community never turns your pocket into a vibrating brick. You decide the cadence; it sticks to it.",
			}, []string{"Web push (opt-in)", "Per-event toggles", "Digest batching", "Works on mobile", "No app required"})
		</div>
	</section>
}

// landingDeepRow — one prose pillar: a heading, a couple of explanatory
// paragraphs, and a chip list of the concrete sub-capabilities. Alternating
// layout is handled in CSS (:nth-child). Reusable so landingDeepDive stays data.
templ landingDeepRow(title string, paras []string, chips []string) {
	<article class="lp-deep-row">
		<div class="lp-deep-copy">
			<h3 class="lp-deep-title">{ title }</h3>
			for _, p := range paras {
				<p class="lp-deep-p">{ p }</p>
			}
		</div>
		<div class="lp-deep-aside" aria-hidden="true">
			<ul class="lp-chiplist">
				for _, c := range chips {
					<li class="lp-chip">{ c }</li>
				}
			</ul>
		</div>
	</article>
}

// landingPrivacy — the "own your data" conviction band. Self-hosting is the
// whole point, so it gets its own statement rather than being buried in a
// feature card. Strong, honest, keyword-relevant prose for both humans and
// search engines.
templ landingPrivacy() {
	<section class="lp-section" aria-label="Own your data">
		<div class="lp-section-head">
			<span class="lp-kicker">Yours, end to end</span>
			<h2 class="lp-h2">Your community, on your terms</h2>
		</div>
		<div class="lp-prose-narrow">
			<p>When your community lives on someone else's platform, you're a tenant. The rules can change, the feed can be reordered, your history can be paywalled, and one policy update can wall off years of conversation. { brandName() } takes the opposite bet: you host it, so it's yours.</p>
			<p>All of it — every message, thread, file and account — sits in a single database and an uploads folder on a server you control. There's no telemetry phoning home, no analytics broker in the middle, and no third-party AI service reading your discussions. Backing up the whole thing is as simple as copying a file, and migrating away is just taking that file with you.</p>
			<p>It's open source under the AGPL-3.0 licence, so you can read exactly what it does, change it, and trust that it isn't quietly working against you. No ads. No algorithm deciding who sees what. No account you can be locked out of by a company you've never spoken to.</p>
		</div>
	</section>
}

// landingTech — "boring tech that lasts", for the technically-minded reader
// evaluating whether this is something they can actually run and maintain. A
// short pitch plus a pill list of the load-bearing, deliberately-unfashionable
// choices. No env/config detail — just the shape of the thing.
templ landingTech() {
	<section id="tech" class="lp-section lp-section-alt" aria-label="Technology">
		<div class="lp-section-head">
			<span class="lp-kicker">Built to outlast the hype cycle</span>
			<h2 class="lp-h2">Boring technology, on purpose</h2>
			<p class="lp-lead">No microservices to orchestrate, no JavaScript framework to keep alive, no database cluster to babysit. { brandName() } is one small program that does a lot — the kind of software you can still run, and still understand, years from now.</p>
		</div>
		<ul class="lp-tech">
			<li class="lp-tech-item"><strong>Single binary</strong><span>The whole server is one compiled program — copy it, run it, done.</span></li>
			<li class="lp-tech-item"><strong>SQLite storage</strong><span>One file holds your whole community. Trivial to back up, trivial to move.</span></li>
			<li class="lp-tech-item"><strong>Server-rendered HTML</strong><span>Fast pages and live updates with no heavy front-end build to maintain.</span></li>
			<li class="lp-tech-item"><strong>Runs on tiny hardware</strong><span>Happy on a $5 VPS or a Raspberry Pi — a lightweight container image.</span></li>
			<li class="lp-tech-item"><strong>Open source (AGPL-3.0)</strong><span>Read it, audit it, change it. The code is the contract.</span></li>
			<li class="lp-tech-item"><strong>Deploy in minutes</strong><span>One container command and your community is live — no pipeline, no cluster.</span></li>
		</ul>
	</section>
}

// connCurlSample is the two-command curl peek shown in the developers section.
// Kept as a Go string (not inline templ text) so templ never tries to parse the
// JSON braces as a template expression (the bare-`{` gotcha) and so the `$`,
// quotes and emoji pass through verbatim.
func connCurlSample() string {
	return `# receive — open the signed SSE stream of channel messages
curl -N "$BASE/bots/$ID/stream?exp=0&sig=$SIG"

# send — one signed POST; it appears as a human member's message
curl -X POST "$BASE/bots/$ID/send" \
  -H "X-Signature: sha256=$SIG" \
  --data-raw '{"channel":"support","body":"on it 👋"}'`
}

// landingConnectors — the "build on it" / developer section. The headline pitch
// for external connectors (run an outside program as a human member over a
// signed SSE stream) paired with a curl peek and CTAs into /dev/docs. This is
// the page's developer differentiator, so it gets a dedicated split layout
// rather than another card grid.
templ landingConnectors() {
	<section id="developers" class="lp-section" aria-label="External connectors and developer docs">
		<div class="lp-section-head">
			<span class="lp-kicker">Build on it</span>
			<h2 class="lp-h2">Plug the outside world in — as a member</h2>
			<p class="lp-lead">Connectors let any external program take part in a channel <strong>as if it were a person</strong>: it holds open one signed SSE stream to receive messages and POSTs signed requests to send them back. A support desk, a shop concierge, a bridge to another network, your own bot — from the community's side it's just another member typing.</p>
		</div>
		<div class="lp-conn">
			<div class="lp-conn-copy">
				<ul class="lp-conn-points">
					<li><strong>Acts as a human.</strong> Roster presence, @mentions, replies and a profile — every member feature works for it for free, no bot badge.</li>
					<li><strong>Live and two-way.</strong> A persistent JSON SSE stream in, signed POSTs out — not fire-and-forget webhooks.</li>
					<li><strong>Simple, rotatable auth.</strong> Read with a signed URL, write with a body HMAC. One secret powers both; rotating it revokes both at once.</li>
					<li><strong>Admin-granted powers.</strong> Grant just <code>send</code>, or add <code>delete</code>, <code>ban</code> and <code>rename</code> to let it moderate.</li>
					<li><strong>Tiny Go SDK.</strong> A dependency-free client and a ~200-line runnable example — or speak the wire yourself in any language.</li>
				</ul>
				<div class="lp-conn-cta">
					<a href="/dev/docs/connectors" class="btn lp-btn-lg">Read the connector docs</a>
					<a href="/dev/docs" class="btn ghost lp-btn-lg">All developer docs</a>
				</div>
			</div>
			<figure class="lp-term" aria-label="Example: receive and send over a connector">
				<div class="lp-term-bar">
					<span class="lp-dot"></span><span class="lp-dot"></span><span class="lp-dot"></span>
					<span class="lp-term-title">connector.sh</span>
				</div>
				<pre class="lp-term-pre"><code>{ connCurlSample() }</code></pre>
			</figure>
		</div>
	</section>
}

// landingFAQ — long-tail question/answer accordions, rendered from the same
// data that powers the FAQPage structured data (structuredData). Native
// <details> so it works with zero JS. Great for humans skimming objections and
// for answer engines quoting a clean Q→A.
templ landingFAQ() {
	<section id="faq" class="lp-section" aria-label="Frequently asked questions">
		<div class="lp-section-head">
			<span class="lp-kicker">Good questions</span>
			<h2 class="lp-h2">Frequently asked questions</h2>
		</div>
		<div class="lp-faq">
			for i, f := range landingFAQItems() {
				<details class="lp-faq-item" open?={ i == 0 }>
					<summary class="lp-faq-q">{ f.Q }</summary>
					<p class="lp-faq-a">{ f.A }</p>
				</details>
			}
		</div>
	</section>
}

// landingFinalCTA — closing conversion band.
templ landingFinalCTA() {
	<section class="lp-cta-band" aria-label="Get started">
		<h2 class="lp-cta-title">Ready when you are.</h2>
		<p class="lp-cta-sub">Bring your community into one calm, fast home you actually own.</p>
		<div class="lp-hero-actions lp-cta-actions">
			<a href="/register" class="btn lp-btn-lg">{ ctaPrimaryLabel() }</a>
			<a href="/login" class="btn ghost lp-btn-lg">Sign in</a>
		</div>
	</section>
}

// landingFooter — marketing footer with brand, auth links and build version.
templ landingFooter() {
	<footer class="lp-footer">
		<div class="lp-footer-brand">
			<a href="/" class="lp-logo">
				<span class="lp-logo-mark" aria-hidden="true">◇</span>
				<span class="lp-logo-word">{ brandName() }</span>
			</a>
			<p class="lp-footer-tag">{ landingTagline }.</p>
		</div>
		<nav class="lp-footer-links" aria-label="Footer">
			<a href="/login">Sign in</a>
			<a href="/register">{ ctaPrimaryLabel() }</a>
			<a href={ templ.URL(landingRepoURL) } target="_blank" rel="noopener">GitHub</a>
		</nav>
		<div class="lp-footer-meta">
			<span>Built by <a href="https://ituoga.lt" target="_blank" rel="noopener">ituoga.lt</a> and Claude</span>
			<span class="fc-version" title="Build version">{ Version }</span>
		</div>
	</footer>
}
