package templ

import (
	"strconv"
	"strings"

	"github.com/atvirokodosprendimai/forumchat/internal/render"
)

// AgentThreadView is one row in the conversation sidebar.
type AgentThreadView struct {
	ID         string
	Title      string
	Visibility string // private | shared
	Active     bool
}

// AgentMsgView is one rendered turn in the active conversation.
type AgentMsgView struct {
	ID          string
	Role        string
	BodyHTML    string
	BodyMD      string // raw source — drives the view-source / download / preview tools
	Status      string
	Error       string
	IsUser      bool
	IsAssistant bool
	Generating  bool
	Interrupted bool
	Errored     bool
	CanShare    bool
	ToolCalls   []AgentToolView
}

// AgentToolView is one MCP tool the assistant called this turn, shown as a chip
// above the answer so members see the agent's tool use.
type AgentToolView struct {
	Server string // "internal" or an MCP server name
	Name   string
	Args   string // compact JSON arguments, shown on hover
	Result string // tool output text, revealed on expand
	OK     bool
}

// AgentOptionView is one selectable agent in the "new chat" picker.
type AgentOptionView struct {
	ID     string
	Name   string
	Vision bool
}

// AgentRefView is one result in the $-reference autocomplete (an agent thread
// title or a forum subject).
type AgentRefView struct {
	Kind  string // agent | forum
	ID    string
	Title string
}

// AgentAdminView is one agent in the admin manager. The stored API key is
// never echoed back — APIKeySet just tells the form whether one exists.
type AgentAdminView struct {
	ID           string
	Name         string
	Provider     string
	BaseURL      string
	Model        string
	SystemPrompt string
	Vision       bool
	ToolsEnabled bool
	Enabled      bool
	IsSummarizer bool
	APIKeySet    bool
	// Chat participation (chat-agents): this agent joins the live chat channel
	// as a kind='bot' participant when InChatEnabled, triggered per TriggerMode.
	InChatEnabled bool
	TriggerMode   string // mention | prefix | both | all
	TriggerPrefix string
	AvatarURL     string
	Channels      []AgentChannelOption // community channels + which are bound
}

// AgentChannelOption is one channel checkbox in the agent admin form's
// chat-participation channel picker.
type AgentChannelOption struct {
	ID    string
	Name  string
	Bound bool
}

// AgentPageData drives the whole /agent page.
type AgentPageData struct {
	Viewer          Viewer
	Slug            string
	Threads         []AgentThreadView
	Active          AgentThreadView
	HasActive       bool
	Generating      bool
	Messages        []AgentMsgView
	Channels        []ChannelView // share-to-channel dropdown
	Agents          []AgentOptionView
	ActiveAgentName string
	ActiveAgentID   string // active thread's agent (for the header switcher)
	ActiveVision    bool   // active thread's agent accepts images
	AnyVision       bool // any enabled agent accepts images (empty-state attach)
	HasEnabledAgent bool
	CanShare        bool
}

// AgentPage is the two-pane Agent surface: conversation list on the left,
// active thread + composer on the right.
templ AgentPage(d AgentPageData) {
	@Layout("Agent", d.Viewer) {
		<div data-signals={ agentPageSignals(d) }></div>
		<section class="agent-layout">
			@AgentSidebar(d)
			<div class="agent-main">
				if !d.HasEnabledAgent {
					@AgentSetupBanner(d.Slug, RoleIsAdmin(d.Viewer.Role))
				}
				if d.HasActive {
					<header class="agent-thread-head">
						<div class="agent-thread-headings">
							<h1 class="agent-thread-title">{ d.Active.Title }</h1>
							<div class="agent-thread-sub">
								<span aria-hidden="true">🤖</span>
								if len(d.Agents) > 1 {
									<select class="agent-head-select" data-bind="agent_active" data-on:change={ "@post('/c/" + d.Slug + "/agent/" + d.Active.ID + "/agent')" } aria-label="Model">
										for _, a := range d.Agents {
											<option value={ a.ID } selected?={ a.ID == d.ActiveAgentID }>
												{ a.Name }
												if a.Vision {
													{ " 👁" }
												}
											</option>
										}
									</select>
								} else {
									<span>{ d.ActiveAgentName }</span>
								}
							</div>
						</div>
						<div class="agent-thread-tools">
							@agentVisibilityBadge(d.Active.Visibility)
							<button
								class="ghost agent-danger"
								data-on:click={ "confirm('Delete this conversation?') && @post('/c/" + d.Slug + "/agent/" + d.Active.ID + "/delete')" }
							>🗑</button>
						</div>
					</header>
					@AgentMessages(d.Slug, d.Active.ID, d.Messages)
					@AgentComposer(d.Slug, d.Active.ID, d.ActiveVision)
					<div id="agent-stream-open" data-init={ "@get('/c/" + d.Slug + "/agent/" + d.Active.ID + "/stream', {openWhenHidden: true})" }></div>
					if d.CanShare {
						@AgentShareDialog(d.Slug, d.Active.ID, d.Channels)
					}
				} else if d.HasEnabledAgent {
					@AgentEmptyState(d.Slug, d.AnyVision)
				}
			</div>
		</section>
		<div id="agent-notice" aria-live="polite"></div>
		<script src={ "/static/agent-refs.js?v=" + AssetVer("agent-refs.js") } defer></script>
	}
}

// AgentSidebar is the conversation list. The agent + visibility selects and
// "New chat" button create a thread via POST /agent/new.
templ AgentSidebar(d AgentPageData) {
	<aside class="agent-sidebar">
		<div class="agent-sidebar-head">
			if len(d.Agents) > 1 {
				<select class="agent-vis-select" data-bind="agent_pick" aria-label="Agent">
					for _, a := range d.Agents {
						<option value={ a.ID }>{ a.Name }</option>
					}
				</select>
			}
			<select class="agent-vis-select" data-bind="agent_visibility" aria-label="New conversation visibility">
				<option value="private">🔒 Private</option>
				<option value="shared">👥 Shared</option>
			</select>
			<button class="agent-new" data-on:click={ "@post('/c/" + d.Slug + "/agent/new')" }>＋ New chat</button>
		</div>
		<nav class="agent-thread-list">
			if len(d.Threads) == 0 {
				<p class="muted agent-empty-hint">No conversations yet.</p>
			}
			for _, t := range d.Threads {
				<a
					href={ templ.URL("/c/" + d.Slug + "/agent/" + t.ID) }
					class={ "agent-thread-link", templ.KV("active", t.Active) }
				>
					@agentVisibilityIcon(t.Visibility)
					<span class="agent-thread-link-title">{ t.Title }</span>
				</a>
			}
		</nav>
	</aside>
}

// AgentMessages is the fat-morph target. The container owns the scroll and a
// one-time data-init for the initial/post-send jump; the anchor handles
// stick-to-bottom during streaming.
templ AgentMessages(slug, threadID string, msgs []AgentMsgView) {
	<div id="agent-messages" class="agent-messages" data-on:scroll="$_agent_stick = (el.scrollHeight - el.scrollTop - el.clientHeight) < 100">
		if len(msgs) == 0 {
			<div class="agent-hello">
				<div class="agent-hello-icon">🤖</div>
				<p>Ask me anything. I'll stream the answer as I think.</p>
			</div>
		}
		for _, m := range msgs {
			@AgentBubble(slug, threadID, m)
		}
		@AgentScrollAnchor()
	</div>
}

// AgentScrollAnchor keeps the view pinned to the bottom DURING streaming, but
// only when the reader is already near the bottom (within 150px) — so reading
// earlier output isn't interrupted. data-init re-fires on every
// WithModeReplace patch (idiomorph remounts the replaced anchor).
templ AgentScrollAnchor() {
	<div id="agent-scroll-anchor" data-init="if($_agent_stick){const m=el.parentElement; if(m){m.scrollTo({top:m.scrollHeight, behavior:'instant'})}}"></div>
}

// AgentBubble renders one turn.
// AgentToolChips shows the MCP tools the assistant used this turn. Each chip is
// a <details> so members can expand the raw tool result; ✓ / ⚠ flags success.
templ AgentToolChips(calls []AgentToolView) {
	<div class="agent-tools">
		for _, c := range calls {
			<details class="agent-tool-chip">
				<summary title={ c.Args }>
					if c.OK {
						<span class="agent-tool-ok">🔧</span>
					} else {
						<span class="agent-tool-bad">⚠</span>
					}
					<span class="agent-tool-name">{ c.Name }</span>
					<span class="agent-tool-server">{ c.Server }</span>
				</summary>
				<pre class="agent-tool-result">{ c.Result }</pre>
			</details>
		}
	</div>
}

templ AgentBubble(slug, threadID string, m AgentMsgView) {
	if m.IsUser {
		<div class="agent-row user" id={ "agent-msg-" + m.ID }>
			<div class="agent-bubble user">@templ.Raw(render.LinkNewTab(render.RichHTML(m.BodyHTML)))</div>
		</div>
	} else if m.IsAssistant {
		<div class="agent-row assistant" id={ "agent-msg-" + m.ID }>
			<div class="agent-avatar" aria-hidden="true">🤖</div>
			<div class="agent-bubble assistant">
				if len(m.ToolCalls) > 0 {
					@AgentToolChips(m.ToolCalls)
				}
				if m.Generating && m.BodyHTML == "" {
					<span class="agent-typing" aria-label="thinking"><span></span><span></span><span></span></span>
				} else {
					<div class="agent-body">@templ.Raw(render.LinkNewTab(render.RichHTML(m.BodyHTML)))</div>
				}
				if m.Generating {
					<span class="agent-cursor" aria-hidden="true"></span>
				}
				if m.Errored {
					<p class="agent-error">⚠ { m.Error }</p>
				}
				if m.Interrupted {
					<p class="agent-stopped">■ stopped</p>
				}
				if !m.Generating && render.LooksLikeHTML(m.BodyMD) {
					@SourceTools(m.BodyMD, "agent-reply.html", render.IsHTMLDocument(m.BodyMD))
				} else if !m.Generating && m.BodyMD != "" {
					@ReplyDownload(m.BodyMD, render.WrapHTMLDocument(m.BodyHTML, "Agent reply"), "agent-reply")
				}
				<div class="agent-bubble-actions">
					if m.Interrupted || m.Errored {
						<button class="agent-link-btn" data-on:click={ "@post('/c/" + slug + "/agent/" + threadID + "/regenerate')" }>⟳ Regenerate</button>
					}
					if m.CanShare {
						<button class="agent-link-btn" data-on:click={ "$agent_share_msg_id='" + m.ID + "'; $_agent_share_open=true" }>↗ Share to channel</button>
					}
				</div>
			</div>
		</div>
	}
}

// AgentComposer is the message box for an existing thread. vision adds an image
// attach affordance. Enter sends, Shift+Enter newlines; the button flips to
// Stop while $agent_generating.
templ AgentComposer(slug, threadID string, vision bool) {
	<div class="agent-composer-wrap" id="agent-composer">
		if vision {
			<div class="agent-attach-preview" data-show="$agent_image_data !== ''">
				<img data-attr:src="$agent_image_data" alt="attachment"/>
				<button type="button" class="agent-attach-clear" data-on:click="$agent_image_data=''" aria-label="Remove image">✕</button>
			</div>
		}
		<div class="agent-ref-anchor">
			<div id="agent-ref-results" class="agent-ref-dropdown">
				@AgentRefResults(slug, nil)
			</div>
		</div>
		<div class="agent-composer">
			if vision {
				<label class="agent-attach" title="Attach image">📎
					<input type="file" accept="image/*" hidden data-on:change="window.fcPickImage(evt,'agent_image_data')"/>
				</label>
			}
			<div
				id="agent-editor"
				class="agent-input agent-editor"
				contenteditable="true"
				role="textbox"
				aria-multiline="true"
				data-placeholder="Message the agent…  ($ to reference a thread)"
				data-effect="$agent_body === '' && window.fcAgentClearEditorIfNeeded && window.fcAgentClearEditorIfNeeded()"
				data-on:input={ "window.fcAgentEditorInput && window.fcAgentEditorInput(el, '" + slug + "')" }
				data-on:keydown={ "window.fcAgentEditorKeydown && window.fcAgentEditorKeydown(evt, el, '" + slug + "', '" + threadID + "')" }
				data-on:paste="window.fcPasteImage(evt,'agent_image_data')"
			></div>
			<input type="hidden" data-bind="agent_body"/>
			<input type="hidden" id="agent-refs" data-bind="agent_refs"/>
			<input type="hidden" data-bind="agent_image_data"/>
			<input
				type="hidden"
				id="agent-ref-query"
				data-bind="agent_ref_query"
				data-on:input__debounce.180ms={ "@get('/c/" + slug + "/agent/refs')" }
			/>
			<div class="agent-composer-actions">
				<button
					type="button"
					class="agent-send"
					data-show="!$agent_generating"
					data-on:click={ "($agent_body.trim()||$agent_image_data) && @post('/c/" + slug + "/agent/" + threadID + "/send')" }
				>Send</button>
				<button
					type="button"
					class="agent-stop"
					data-show="$agent_generating"
					data-on:click={ "@post('/c/" + slug + "/agent/" + threadID + "/stop')" }
				>■ Stop</button>
			</div>
		</div>
	</div>
}

// AgentRefResults is the $-reference autocomplete RESULTS (morph target for
// /agent/refs). It is the INNER list only — the outer #agent-ref-results
// wrapper (whose `.open` class the JS toggles for visibility) is rendered once
// in the composer and never morphed, so a search response can't close the
// dropdown by resetting its class. Each item carries the title in data-title.
templ AgentRefResults(slug string, refs []AgentRefView) {
	<div id="agent-ref-list">
		for _, ref := range refs {
			<button type="button" class="agent-ref-item" data-title={ ref.Title } data-id={ ref.ID } data-kind={ ref.Kind } data-on:click="window.fcAgentInsertRef && window.fcAgentInsertRef(el)">
				<span class="agent-ref-kind" aria-hidden="true">{ agentRefIcon(ref.Kind) }</span>
				<span class="agent-ref-item-title">{ ref.Title }</span>
			</button>
		}
		if len(refs) == 0 {
			<div class="agent-ref-empty muted">No matches</div>
		}
	</div>
}

func agentRefIcon(kind string) string {
	switch kind {
	case "forum":
		return "📋"
	case "project":
		return "📂"
	case "issue":
		return "🐞"
	case "discussion":
		return "💬"
	default:
		return "🤖"
	}
}

// AgentEmptyState is shown when the member has no active thread. The hero
// composer creates a thread (with the picked agent) AND sends the first prompt.
templ AgentEmptyState(slug string, anyVision bool) {
	<div class="agent-empty">
		<div class="agent-empty-icon" aria-hidden="true">🤖</div>
		<h1>Agent</h1>
		<p class="muted">Your AI assistant. Pick an agent + Private/Shared in the sidebar, then start a conversation.</p>
		<div class="agent-composer-wrap hero">
			if anyVision {
				<div class="agent-attach-preview" data-show="$agent_image_data !== ''">
					<img data-attr:src="$agent_image_data" alt="attachment"/>
					<button type="button" class="agent-attach-clear" data-on:click="$agent_image_data=''" aria-label="Remove image">✕</button>
				</div>
			}
			<div class="agent-composer">
				if anyVision {
					<label class="agent-attach" title="Attach image">📎
						<input type="file" accept="image/*" hidden data-on:change="window.fcPickImage(evt,'agent_image_data')"/>
					</label>
				}
				<textarea
					class="agent-input"
					data-bind="agent_body"
					rows="1"
					placeholder="Ask the agent anything…"
					data-on:input="el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,200)+'px'"
					data-on:paste="window.fcPasteImage(evt,'agent_image_data')"
					data-on:keydown={ "if(evt.key==='Enter' && !evt.shiftKey){evt.preventDefault(); if($agent_body.trim()||$agent_image_data){@post('/c/" + slug + "/agent/new')}}" }
				></textarea>
				<input type="hidden" data-bind="agent_image_data"/>
				<div class="agent-composer-actions">
					<button type="button" class="agent-send" data-on:click={ "($agent_body.trim()||$agent_image_data) && @post('/c/" + slug + "/agent/new')" }>Send</button>
				</div>
			</div>
		</div>
	</div>
}

// AgentShareDialog copies an assistant answer into a chat channel.
templ AgentShareDialog(slug, threadID string, channels []ChannelView) {
	<div class="agent-modal-overlay" data-cloak data-show="$_agent_share_open" data-on:click="$_agent_share_open=false"></div>
	<div class="agent-modal" data-cloak data-show="$_agent_share_open" role="dialog" aria-label="Share to channel">
		<h3>Share to a channel</h3>
		<p class="muted">Post this answer into a public chat channel.</p>
		<select class="agent-channel-select" data-bind="agent_share_channel">
			<option value="">Choose a channel…</option>
			for _, c := range channels {
				<option value={ c.Slug }>#{ c.Name }</option>
			}
		</select>
		<div class="agent-modal-actions">
			<button class="ghost" data-on:click="$_agent_share_open=false">Cancel</button>
			<button class="agent-send" data-on:click={ "$agent_share_channel && @post('/c/" + slug + "/agent/" + threadID + "/share')" }>Share</button>
		</div>
	</div>
}

// AgentSetupBanner nudges admins (and informs members) when no agent is enabled.
templ AgentSetupBanner(slug string, isAdmin bool) {
	<div class="agent-banner">
		if isAdmin {
			<span>No AI agent is enabled yet. </span>
			<a href={ templ.URL("/c/" + slug + "/admin/ai") }>Add one in Admin → AI →</a>
		} else {
			<span>The AI assistant isn't available for this community yet.</span>
		}
	</div>
}

// AgentNotice is a transient toast patched into #agent-notice after an action.
templ AgentNotice(msg string) {
	<div id="agent-notice" aria-live="polite">
		<div class="agent-toast" data-init="setTimeout(() => el.remove(), 3500)">{ msg }</div>
	</div>
}

templ agentVisibilityBadge(vis string) {
	if vis == "shared" {
		<span class="agent-badge shared">👥 Shared</span>
	} else {
		<span class="agent-badge private">🔒 Private</span>
	}
}

templ agentVisibilityIcon(vis string) {
	if vis == "shared" {
		<span class="agent-thread-icon" title="Shared">👥</span>
	} else {
		<span class="agent-thread-icon" title="Private">🔒</span>
	}
}

// agentPageSignals seeds the generating flag + default agent pick into the bag
// on page load.
func agentPageSignals(d AgentPageData) string {
	gen := "false"
	if d.Generating {
		gen = "true"
	}
	pick := ""
	if len(d.Agents) > 0 {
		pick = d.Agents[0].ID
	}
	active := d.ActiveAgentID
	if active == "" {
		active = pick
	}
	return `{"agent_generating":` + gen + `,"agent_pick":` + strconv.Quote(pick) +
		`,"agent_active":` + strconv.Quote(active) + `}`
}

// --- admin: manage agents -------------------------------------------------

// AgentAdminPage lists a community's agents with an inline editor, plus the
// connected MCP servers the tools-enabled agents can use.
templ AgentAdminPage(v Viewer, slug string, agents []AgentAdminView, servers []MCPServerView) {
	@Layout("AI agents", v) {
		<section class="card agent-admin">
			<h1>AI agents</h1>
			<p class="muted">Each agent is its own model + system prompt. Enable an agent to let members chat with it. Turn on “vision” for models that accept images, and “tools” to let it search this community and use connected MCP servers.</p>
			@AgentAdminList(slug, agents)
			<button class="agent-new agent-add-btn" data-on:click={ "@get('/c/" + slug + "/admin/ai/new')" }>＋ Add agent</button>
			<div id="ai-agent-form"></div>
		</section>
		<section class="card agent-admin">
			<h1>MCP servers</h1>
			<p class="muted">Tools an agent can call. The built-in <strong>internal search</strong> (full-text search over this community’s chat &amp; forum) is always available to tools-enabled agents. Connect more MCP servers below — every tools-enabled agent in this community can use the enabled ones.</p>
			<div class="agent-mcp-internal">
				<span class="agent-badge">🔧 internal · search</span>
				<span class="muted">built-in · always on</span>
			</div>
			@AgentMCPList(slug, servers)
			@AgentMCPForm(slug)
		</section>
	}
}

// MCPServerView is one connected MCP server in the admin list.
type MCPServerView struct {
	ID        string
	Name      string
	Transport string // stdio | http
	Target    string // command+args, or url
	Enabled   bool
}

// AgentMCPList is the morph target after connect/toggle/delete.
templ AgentMCPList(slug string, servers []MCPServerView) {
	<div id="ai-mcp-list" class="agent-admin-list">
		for _, m := range servers {
			<div class="agent-admin-card">
				<div class="agent-admin-card-main">
					<strong>{ m.Name }</strong>
					<span class="agent-admin-meta">{ m.Transport } · { m.Target }</span>
					<div class="agent-admin-badges">
						if m.Enabled {
							<span class="agent-badge shared">enabled</span>
						} else {
							<span class="agent-badge private">disabled</span>
						}
					</div>
				</div>
				<div class="agent-admin-card-actions">
					<button class="agent-link-btn" data-on:click={ "@post('/c/" + slug + "/admin/ai/mcp/" + m.ID + "/toggle')" }>
						if m.Enabled {
							Disable
						} else {
							Enable
						}
					</button>
					<button class="agent-link-btn agent-danger" data-on:click={ "confirm('Disconnect MCP server “" + m.Name + "”?') && @post('/c/" + slug + "/admin/ai/mcp/" + m.ID + "/delete')" }>Disconnect</button>
				</div>
			</div>
		}
	</div>
}

// AgentMCPForm is the connect-a-server form. mcp_transport drives which fields
// matter; both stdio and http fields are shown and validated server-side.
templ AgentMCPForm(slug string) {
	<div id="ai-mcp-form" class="agent-config-form" data-signals={ mcpFormSignals() }>
		<h2 class="agent-form-title">Connect an MCP server</h2>
		<label>
			<span>Name</span>
			<input type="text" data-bind="mcp_name" placeholder="e.g. Filesystem, GitHub, Brave Search"/>
		</label>
		<label>
			<span>Transport</span>
			<select data-bind="mcp_transport">
				<option value="stdio">stdio (local command)</option>
				<option value="http">http (streamable URL)</option>
			</select>
		</label>
		<div data-show="$mcp_transport === 'stdio'">
			<label>
				<span>Command</span>
				<input type="text" data-bind="mcp_command" placeholder="npx"/>
			</label>
			<label>
				<span>Arguments <span class="muted">(space-separated)</span></span>
				<input type="text" data-bind="mcp_args" placeholder="-y @modelcontextprotocol/server-filesystem /data"/>
			</label>
			<label>
				<span>Environment <span class="muted">(one KEY=value per line)</span></span>
				<textarea data-bind="mcp_env" rows="2" placeholder="API_KEY=…"></textarea>
			</label>
		</div>
		<div data-show="$mcp_transport === 'http'">
			<label>
				<span>URL</span>
				<input type="text" data-bind="mcp_url" placeholder="https://mcp.example.com/mcp"/>
			</label>
			<label>
				<span>Headers <span class="muted">(one Key: Value per line)</span></span>
				<textarea data-bind="mcp_headers" rows="2" placeholder="Authorization: Bearer …"></textarea>
			</label>
		</div>
		<div class="agent-config-actions">
			<button type="button" class="agent-send" data-on:click={ "@post('/c/" + slug + "/admin/ai/mcp')" }>Connect</button>
			@AgentMCPStatus("")
		</div>
	</div>
}

// AgentMCPStatus is the inline save/connect status line (its own id so it can be
// patched independently of the form, preserving the typed fields on error).
templ AgentMCPStatus(status string) {
	<span id="ai-mcp-status" class="agent-config-status">{ status }</span>
}

func mcpFormSignals() string {
	return `{"mcp_name":"","mcp_transport":"stdio","mcp_command":"","mcp_args":"","mcp_url":"","mcp_headers":"","mcp_env":""}`
}

// AgentAdminList is the morph target after create/delete.
templ AgentAdminList(slug string, agents []AgentAdminView) {
	<div id="ai-agent-list" class="agent-admin-list">
		if len(agents) == 0 {
			<p class="muted">No agents yet. Add one to enable the Agent feature.</p>
		}
		for _, a := range agents {
			@AgentCard(slug, a)
		}
	</div>
}

templ AgentCard(slug string, a AgentAdminView) {
	<div class="agent-admin-card">
		<div class="agent-admin-card-main">
			<strong>{ a.Name }</strong>
			<span class="agent-admin-meta">{ a.Provider } · { a.Model }</span>
			<div class="agent-admin-badges">
				if a.Enabled {
					<span class="agent-badge shared">enabled</span>
				} else {
					<span class="agent-badge private">disabled</span>
				}
				if a.Vision {
					<span class="agent-badge">👁 vision</span>
				}
				if a.ToolsEnabled {
					<span class="agent-badge">🔧 tools</span>
				}
				if a.IsSummarizer {
					<span class="agent-badge">📝 /summary</span>
				}
			</div>
		</div>
		<div class="agent-admin-card-actions">
			<button class="agent-link-btn" data-on:click={ "@get('/c/" + slug + "/admin/ai/" + a.ID + "/edit')" }>Edit</button>
			<button class="agent-link-btn agent-danger" data-on:click={ "confirm('Delete agent “" + a.Name + "”? Its conversations are removed too.') && @post('/c/" + slug + "/admin/ai/" + a.ID + "/delete')" }>Delete</button>
		</div>
	</div>
}

// AgentAdminForm is the create/edit editor, patched into #ai-agent-form. An
// empty a.ID means "create"; data-signals seeds the fields server-side (safe
// for arbitrary system prompts via strconv.Quote).
templ AgentAdminForm(slug string, a AgentAdminView, status string) {
	<div id="ai-agent-form" class="agent-config-form" data-signals={ agentFormSignals(a) }>
		<h2 class="agent-form-title">
			if a.ID == "" {
				New agent
			} else {
				Edit agent
			}
		</h2>
		<label>
			<span>Name</span>
			<input type="text" data-bind="ai_name" placeholder="e.g. Helpdesk, Coder, Lawyer"/>
		</label>
		<label>
			<span>Provider</span>
			<select data-bind="ai_provider">
				<option value="ollama">Ollama (local / self-hosted)</option>
			</select>
		</label>
		<label>
			<span>Base URL</span>
			<input type="text" data-bind="ai_base_url" placeholder="http://localhost:11434"/>
		</label>
		<label>
			<span>Model</span>
			<input type="text" data-bind="ai_model" placeholder="llama3.2 (or a vision model like llava)"/>
		</label>
		<label>
			<span>System prompt <span class="muted">(this agent's personality)</span></span>
			<textarea data-bind="ai_system_prompt" rows="4" placeholder="You are…"></textarea>
		</label>
		<label class="agent-config-toggle">
			<input type="checkbox" data-bind="ai_vision"/>
			<span>Model supports vision (allow image attachments)</span>
		</label>
		<label class="agent-config-toggle">
			<input type="checkbox" data-bind="ai_tools"/>
			<span>Agent supports tools (let this agent use the internal search + connected MCP servers)</span>
		</label>
		<label class="agent-config-toggle">
			<input type="checkbox" data-bind="ai_summarizer"/>
			<span>Use for /summary channel summaries (one per community — combine with vision to summarise images too)</span>
		</label>
		<label>
			<span>API key <span class="muted">(hosted providers; blank for Ollama)</span></span>
			<input type="password" data-bind="ai_api_key" placeholder={ agentKeyPlaceholder(a.APIKeySet) } autocomplete="off"/>
		</label>
		<label class="agent-config-toggle">
			<input type="checkbox" data-bind="ai_enabled"/>
			<span>Enabled (members can chat with this agent)</span>
		</label>
		<fieldset class="agent-chat-fieldset">
			<legend>Chat participation</legend>
			<label class="agent-config-toggle">
				<input type="checkbox" data-bind="ai_in_chat"/>
				<span>Join the live chat (appears in the roster, @mentionable as a bot)</span>
			</label>
			<div data-show="$ai_in_chat" class="agent-chat-fields">
				<label>
					<span>Avatar URL <span class="muted">(optional)</span></span>
					<input type="text" data-bind="ai_avatar_url" placeholder="https://… (blank → 🤖)"/>
				</label>
				<label>
					<span>Trigger</span>
					<select data-bind="ai_trigger_mode">
						<option value="mention">{ "@mention only" }</option>
						<option value="prefix">Line prefix only</option>
						<option value="both">Mention or prefix</option>
						<option value="all">Every message (dedicated channel)</option>
					</select>
				</label>
				<label data-show="$ai_trigger_mode === 'prefix' || $ai_trigger_mode === 'both'">
					<span>Prefix <span class="muted">(line starting with this summons the bot)</span></span>
					<input type="text" data-bind="ai_trigger_prefix" maxlength="3" placeholder="."/>
				</label>
				<div class="agent-chat-channels">
					<span class="agent-chat-channels-label">Channels</span>
					if len(a.Channels) == 0 {
						<p class="muted">No channels yet.</p>
					} else {
						for _, ch := range a.Channels {
							<label class="agent-config-toggle">
								<input type="checkbox" value={ ch.ID } checked?={ ch.Bound }
									data-on:change={ agentChannelToggleJS() }/>
								<span>#{ ch.Name }</span>
							</label>
						}
					}
				</div>
			</div>
		</fieldset>
		<div class="agent-config-actions">
			<button type="button" class="agent-send" data-on:click={ "@post('/c/" + slug + "/admin/ai')" }>Save</button>
			<button type="button" class="ghost" data-on:click="el.closest('#ai-agent-form').replaceChildren()">Cancel</button>
			if status != "" {
				<span class="agent-config-status">{ status }</span>
			}
		</div>
	</div>
}

func agentKeyPlaceholder(set bool) string {
	if set {
		return "•••••••• (stored — leave blank to keep)"
	}
	return "not set"
}

// agentFormSignals seeds the editor. The API key is intentionally NOT seeded —
// the stored secret is never sent to the browser.
func agentFormSignals(a AgentAdminView) string {
	prov := a.Provider
	if prov == "" {
		prov = "ollama"
	}
	base := a.BaseURL
	if base == "" && a.ID == "" {
		base = "http://localhost:11434"
	}
	mode := a.TriggerMode
	if mode == "" {
		mode = "mention"
	}
	prefix := a.TriggerPrefix
	if prefix == "" {
		prefix = "."
	}
	return `{"ai_agent_id":` + strconv.Quote(a.ID) +
		`,"ai_name":` + strconv.Quote(a.Name) +
		`,"ai_provider":` + strconv.Quote(prov) +
		`,"ai_base_url":` + strconv.Quote(base) +
		`,"ai_model":` + strconv.Quote(a.Model) +
		`,"ai_system_prompt":` + strconv.Quote(a.SystemPrompt) +
		`,"ai_vision":` + agentBoolStr(a.Vision) +
		`,"ai_tools":` + agentBoolStr(a.ToolsEnabled) +
		`,"ai_enabled":` + agentBoolStr(a.Enabled) +
		`,"ai_summarizer":` + agentBoolStr(a.IsSummarizer) +
		`,"ai_in_chat":` + agentBoolStr(a.InChatEnabled) +
		`,"ai_trigger_mode":` + strconv.Quote(mode) +
		`,"ai_trigger_prefix":` + strconv.Quote(prefix) +
		`,"ai_avatar_url":` + strconv.Quote(a.AvatarURL) +
		`,"ai_channels":` + strconv.Quote(agentBoundChannelsCSV(a)) +
		`,"ai_api_key":""}`
}

// agentBoundChannelsCSV joins the currently-bound channel ids into the CSV the
// channel checkboxes maintain in the ai_channels signal.
func agentBoundChannelsCSV(a AgentAdminView) string {
	ids := make([]string, 0, len(a.Channels))
	for _, ch := range a.Channels {
		if ch.Bound {
			ids = append(ids, ch.ID)
		}
	}
	return strings.Join(ids, ",")
}

// agentChannelToggleJS adds/removes the checkbox's channel id from the
// comma-separated ai_channels signal as the admin ticks channels.
func agentChannelToggleJS() string {
	return "$ai_channels = el.checked " +
		"? ($ai_channels ? $ai_channels + ',' + el.value : el.value) " +
		": $ai_channels.split(',').filter(function(x){return x && x !== el.value}).join(',')"
}

func agentBoolStr(b bool) string {
	if b {
		return "true"
	}
	return "false"
}
