# forumchat — SaaS (.env) example.  →  cp .env.saas.example .env
#
# Used by compose.saas.yaml.example: the app loads this via `env_file`, and the
# Garage bootstrap interpolates the shared secrets (S3 + Garage tokens) from it.
# The compose file sets the docker-network URLs (NATS/Qdrant/Garage/Ollama/SMTP)
# itself, so you do NOT need to set those here.
#
# ── Generate the secrets (REQUIRED — the values below are left BLANK on purpose
#    so boot/garage fail loudly until you fill them in) ─────────────────────────
#   SECRETS_KEY        : openssl rand -hex 16          # 32-char key
#   SESSION_KEY        : openssl rand -hex 24          # 32+ bytes
#   UPLOADS_SIGN_KEY   : openssl rand -hex 24
#   GARAGE_RPC_SECRET  : openssl rand -hex 32          # 32-byte hex (64 chars)
#   GARAGE_ADMIN_TOKEN : openssl rand -hex 32
#
#   S3 keys — Garage requires its OWN format (an arbitrary `openssl rand` value is
#   REJECTED by garage-init's key import). Two ways:
#     a) one-shot:  S3_ACCESS_KEY = "GK$(openssl rand -hex 12)"   # GK + 24 hex
#                   S3_SECRET_KEY = openssl rand -hex 32          # 64 hex chars
#     b) let Garage mint them (after `docker compose up -d garage` is healthy):
#                   docker compose exec garage /garage key create forumchat
#        then paste the printed "Key ID" → S3_ACCESS_KEY and "Secret key" → S3_SECRET_KEY.

# ── Platform identity ───────────────────────────────────────────────────────
SAAS=true
SAAS_BRAND=Commons
# Public URL behind Caddy — use https://<your-domain> (must match Caddyfile).
# The app builds verify links, signed upload URLs and OAuth callbacks from this.
BASE_URL=https://domain.tld
COMMUNITY_SLUG=main
COMMUNITY_NAME=The Community
# Comma-separated emails that get platform god-mode (the /superadmin surface).
SUPERADMIN_EMAILS=you@example.com

# ── Core secrets (REQUIRED in prod+SaaS — boot refuses without these) ────────
# Left blank on purpose: generate each with the openssl command in the header.
SECRETS_KEY=
SESSION_KEY=
UPLOADS_SIGN_KEY=

# ── Object storage (Garage S3) — creds garage-init imports into Garage ──
# S3_ACCESS_KEY / S3_SECRET_KEY must be Garage-format (see header) or garage-init
# fails with "key import HTTP 400". Blank = fail loud until you fill them in.
S3_BUCKET=forumchat
S3_REGION=garage
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Both 64 hex chars: openssl rand -hex 32  (an invalid value = "Invalid RPC secret key")
GARAGE_RPC_SECRET=
GARAGE_ADMIN_TOKEN=

# ── AI / RAG / translate ────────────────────────────────────────────────────
# These flags only make the features AVAILABLE. AI agents, RAG embeddings and
# /translate are BYO PER COMMUNITY — each owner sets its own Ollama/LLM host +
# model + keys at /c/<slug>/settings and pays for its OWN compute. The platform
# runs no Ollama, so the operator pays for ZERO AI compute (only the Qdrant
# vector store). Set any flag to false to remove the feature entirely.
AI_ENABLED=true
TRANSLATE_ENABLED=true
# Fallback embedding model/dim a community inherits if it sets its own embedder
# host but not a model (not a platform-run model — there is no platform Ollama).
RAG_EMBED_MODEL=bge-m3
RAG_EMBED_DIM=1024

# ── Mail (defaults to the bundled Mailpit; point at a real relay for prod) ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=change-me
SMTP_FROM=forumchat@localhost
