services:
  app:
    image: ghcr.io/atvirokodosprendimai/forumchat:latest
    depends_on:
      - nats
      - mailpit
    environment:
      ENV: "prod"
      HTTP_ADDR: ":8080"
      BASE_URL: "http://localhost:8080"
      DB_PATH: "/data/forumchat.db"
      MIGRATE_ON_BOOT: "true"
      NATS_URL: "nats://nats:4222"
      SESSION_KEY: "change-me-to-a-random-32-bytes-min-secret"
      SESSION_MAX_AGE: "720h"
      UPLOADS_DIR: "/uploads"
      UPLOADS_MAX_BYTES: "5242880"
      UPLOADS_SIGN_KEY: "change-me-to-a-random-uploads-sign-key"
      SMTP_HOST: "mailpit"
      SMTP_PORT: "1025"
      SMTP_USER: ""
      SMTP_PASS: ""
      SMTP_FROM: "forumchat@localhost"
      SMTP_TLS: "auto"            # auto|starttls|tls|none — auto upgrades via STARTTLS when offered
      SMTP_TLS_INSECURE: "false"  # set true only for self-signed certs in test envs
      COMMUNITY_SLUG: "main"
      COMMUNITY_NAME: "The Community"
      PRESENCE_TTL: "30s"
      EDIT_GRACE: "15m"
      # WebRTC /rooms relay. Same credentialed TURN server, three transports so
      # guests on UDP-blocking / 443-only networks still connect. Replace the
      # host with your public TURN hostname and the creds with turnserver.conf's.
      ROOMS_STUN_URLS: "stun:stun.l.google.com:19302"
      ROOMS_TURN_URLS: "turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:5349?transport=tcp"
      ROOMS_TURN_USERNAME: "forumchat"
      ROOMS_TURN_PASSWORD: "change-me-to-match-turnserver.conf"
      ROOMS_FORCE_RELAY: "false"  # set true only if direct/STUN paths are unreliable; needs a working TURN
    volumes:
      - app-data:/data
      - app-uploads:/uploads
    ports:
      - "8080:8080"
    restart: unless-stopped

  nats:
    image: nats:2.10-alpine
    command: ["-js", "-sd", "/data"]
    volumes:
      - nats-data:/data
    ports:
      - "4222:4222"
      - "8222:8222"
    restart: unless-stopped

  mailpit:
    image: axllent/mailpit:latest
    ports:
      - "1025:1025"
      - "8025:8025"
    restart: unless-stopped

  # coturn — WebRTC TURN relay for /rooms. Required for guests behind
  # symmetric NAT / mobile carriers / firewalls (same-LAN works without it).
  # network_mode: host is DELIBERATE — coturn hands clients a relay address
  # and an ephemeral UDP port range; Docker's bridge NAT would rewrite both
  # and break media. Edit ./turnserver.conf (copy turnserver.conf.example):
  # set external-ip to this host's PUBLIC ip, and open UDP 3478, TCP 3478,
  # TCP 5349, and the UDP relay range (min-port..max-port) in your firewall.
  coturn:
    image: coturn/coturn:4.6
    network_mode: host
    volumes:
      - ./turnserver.conf:/etc/coturn/turnserver.conf:ro
      # mount TLS cert + key here for turns:5349 (e.g. letsencrypt live dir)
      # - /etc/letsencrypt/live/turn.example.com:/etc/coturn/tls:ro
    restart: unless-stopped

volumes:
  app-data:
  app-uploads:
  nats-data:
