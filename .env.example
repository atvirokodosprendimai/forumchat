ENV=dev
HTTP_ADDR=:8080
BASE_URL=http://localhost:8080
DB_PATH=./data/forumchat.db
MIGRATE_ON_BOOT=true
NATS_URL=nats://127.0.0.1:4222

SESSION_KEY=dev-only-change-me-32-bytes-min!!
SESSION_MAX_AGE=720h

UPLOADS_DIR=./uploads
UPLOADS_MAX_BYTES=104857600
UPLOADS_SIGN_KEY=dev-only-uploads-sign-key-change!!

SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=forumchat@localhost

COMMUNITY_SLUG=main
COMMUNITY_NAME=The Community

PRESENCE_TTL=30s
EDIT_GRACE=15m

# WebRTC /rooms ICE. STUN alone works only on the same LAN; guests behind
# symmetric NAT / mobile / firewalls need a TURN relay or media silently
# stalls (presence shows them, but no video flows). ROOMS_TURN_URLS is a
# comma list so one credentialed TURN server can advertise several transports
# (udp 3478, tcp 3478, turns/TLS 5349 — the last punches 443-only networks).
# TURN REQUIRES username+password; without them the relay is rejected (401)
# and it falls back to STUN. ROOMS_TURN_URL (singular) is the deprecated alias.
# See turnserver.conf.example for the matching coturn server config.
ROOMS_STUN_URLS=stun:stun.l.google.com:19302
# ROOMS_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp,turns:turn.example.com:5349?transport=tcp
# ROOMS_TURN_USERNAME=forumchat
# ROOMS_TURN_PASSWORD=change-me-to-match-turnserver.conf
# ROOMS_FORCE_RELAY=false   # true = TURN-only (iceTransportPolicy=relay); needs a working TURN

# RAG — semantic (vector) search over community content. Needs an Ollama daemon
# serving the embed model (e.g. `ollama pull bge-m3`). Off by default. The
# `rag_search` MCP tool appears for tools-enabled agents only when this is on.
RAG_ENABLED=false
RAG_BACKEND=chromem
RAG_DB_PATH=./data/rag
RAG_EMBED_BASEURL=http://localhost:11434
RAG_EMBED_MODEL=bge-m3
RAG_EMBED_DIM=1024
RAG_CHUNK_TOKENS=2800
RAG_CHUNK_OVERLAP=400
RAG_WORKER_INTERVAL=10
RAG_WORKER_BATCH=64
RAG_SEARCH_DEFAULT_LIMIT=8
# QDRANT_URL=   # reserved; used when RAG_BACKEND=qdrant (not yet implemented)

# Translate — interactive /translate composer typeahead. Type "/translate <text>"
# in chat and a popup offers up to 3 English translations (source language auto-
# detected) to send as yourself; click one or press Enter to take the first.
# Like RAG, it talks to Ollama directly with its OWN endpoint + model (e.g.
# `ollama pull llama3.1`), independent of the per-community AI agents. Off by
# default; with no TRANSLATE_MODEL the command is inert.
TRANSLATE_ENABLED=false
TRANSLATE_BASEURL=http://localhost:11434
TRANSLATE_MODEL=
