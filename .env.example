SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=forumchat@localhost

COMMUNITY_SLUG=main
COMMUNITY_NAME=The Community

PRESENCE_TTL=30s
EDIT_GRACE=15m
